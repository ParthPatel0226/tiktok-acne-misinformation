s_resp = requests.get(\n","    f'https://api.apify.com/v2/actor-runs/{run_id}/dataset/items'\n","    f'?format=json&token={APIFY_TOKEN}&limit=1'\n",")\n","\n","# Check raw response first\n","print('Status code:', items_resp.status_code)\n","print('Response type:', type(items_resp.json()))\n","data = items_resp.json()\n","\n","# Handle both list and dict response\n","if isinstance(data, list):\n","    items = data\n","elif isinstance(data, dict):\n","    # Apify sometimes wraps in {items: [...]} or {data: {items: [...]}}\n","    items = (data.get('items') or\n","             data.get('data', {}).get('items') or\n","             [data])  # fallback: treat whole response as one item\n","else:\n","    items = []\n","\n","print(f'Total items: {len(items)}')\n","\n","if items:\n","    item = items[0]\n","    print('\\nALL KEYS:')\n","    for k, v in sorted(item.items()):\n","        print(f'  {k}: {str(v)[:100]}')\n","    print()\n","    print('Comment-related keys:')\n","    for k, v in item.items():\n","        if any(x in k.lower() for x in ['comment', 'reply', 'text']):\n","            print(f'  {k}: {str(v)[:200]}')\n","else:\n","    print('No items — raw response:')\n","    print(json.dumps(data)[:500])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-zX7T5Of9a1v","executionInfo":{"status":"ok","timestamp":1776891119606,"user_tz":300,"elapsed":905,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"70e1de86-e40f-4845-9bdb-80f7fff0b101"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Status code: 404\n","Response type: <class 'dict'>\n","Total items: 1\n","\n","ALL KEYS:\n","  error: {'type': 'record-not-found', 'message': 'Actor run was not found'}\n","\n","Comment-related keys:\n"]}]},{"cell_type":"code","source":["# ── NLP CLASSIFIER: 7 automatable \"manual\" columns ───────────────────\n","# Uses Claude Haiku on caption + transcript to fill:\n","#   video_format, Video_type, face_visibility, indoor_outdoor,\n","#   condition_extent, condition_duration, condition_recurrence\n","#\n","# Input:  CSV_FINAL (TikTok_Acne_Final_Enriched.csv)\n","# Output: TikTok_Acne_Visual_Classified.csv\n","# Cost:   ~$0.15 for 731 videos (Haiku)\n","\n","import anthropic, json, time, os, pandas as pd\n","from tqdm import tqdm\n","\n","# ── Config ────────────────────────────────────────────────────────────\n","CSV_VISUAL   = f'{DATA_DIR}/TikTok_Acne_Visual_Classified.csv'\n","CKPT_VISUAL  = f'{DATA_DIR}/ckpt_visual.csv'\n","\n","# ── Target columns + allowed values ──────────────────────────────────\n","TAXONOMY = {\n","    'video_format':       ['demo', 'reaction', 'tutorial', 'talking_head', 'before_after', 'other'],\n","    'Video_type':         ['self_made', 'professional', 'duet', 'stitch'],\n","    'face_visibility':    ['yes', 'no', 'partial'],\n","    'indoor_outdoor':     ['indoor', 'outdoor', 'both', 'unknown'],\n","    'condition_extent':   ['face_only', 'face_and_body', 'body_only', 'unknown'],\n","    'condition_duration': ['days', 'weeks', 'months', 'years', 'unknown'],\n","    'condition_recurrence': ['yes', 'no', 'unknown'],\n","}\n","\n","TARGET_COLS  = list(TAXONOMY.keys())\n","DEFAULT_VALS = {\n","    'video_format':         'other',\n","    'Video_type':           'self_made',\n","    'face_visibility':      'unknown',\n","    'indoor_outdoor':       'unknown',\n","    'condition_extent':     'unknown',\n","    'condition_duration':   'unknown',\n","    'condition_recurrence': 'unknown',\n","}\n","\n","# ── Verify ────────────────────────────────────────────────────────────\n","if ANTHROPIC_API_KEY == 'sk-ant-YOUR_KEY_HERE':\n","    raise ValueError('Paste your Anthropic API key in Cell 3 first.')\n","\n","# ── Load CSV ──────────────────────────────────────────────────────────\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","print(f'✅ Loaded: {len(df)} rows')\n","print(f'   Transcript coverage: {(df[\"transcript\"].notna() & (df[\"transcript\"].str.strip() != \"\") & (df[\"transcript\"].str.strip() != \"nan\")).sum()}/731')\n","\n","# ── Claude client ─────────────────────────────────────────────────────\n","client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","\n","SYSTEM_PROMPT = \"\"\"You are a content analyst classifying TikTok acne videos for academic research.\n","Given a video's caption, transcript, and existing metadata — classify the 7 fields below.\n","Respond ONLY with a valid JSON object. No markdown, no explanation, no preamble.\n","\n","FIELD DEFINITIONS AND ALLOWED VALUES:\n","\n","video_format: Overall format of the video\n","  demo         = shows product application or skincare routine\n","  reaction     = creator reacting to something (another video, comment, product)\n","  tutorial     = step-by-step instructional content\n","  talking_head = creator speaking directly to camera, no demo\n","  before_after = explicitly shows before and after skin transformation\n","  other        = none of the above\n","\n","Video_type: Production style\n","  self_made    = filmed by creator themselves (casual, handheld, bedroom)\n","  professional = studio lighting, polished editing, branded production\n","  duet         = TikTok duet format (split screen with another video)\n","  stitch       = TikTok stitch format (clips another video then responds)\n","\n","face_visibility: Is the creator's face clearly visible?\n","  yes     = face clearly shown\n","  no      = face not shown (voiceover, text only, just hands/skin)\n","  partial = face partially shown or obscured\n","\n","indoor_outdoor: Primary filming location\n","  indoor   = inside (bedroom, bathroom, studio, office)\n","  outdoor  = outside (park, street, natural light outdoors)\n","  both     = clearly shows both settings\n","  unknown  = cannot determine from text\n","\n","condition_extent: How much of the body is affected by the skin condition?\n","  face_only      = acne/condition only on face\n","  face_and_body  = acne on both face and body (back, chest etc)\n","  body_only      = acne only on body, not face\n","  unknown        = not mentioned or unclear\n","\n","condition_duration: How long has the creator/subject had the condition?\n","  days    = very recent, days\n","  weeks   = a few weeks\n","  months  = several months\n","  years   = years or long-term/chronic\n","  unknown = not mentioned\n","\n","condition_recurrence: Does the condition keep coming back?\n","  yes     = recurring, chronic, hormonal, keeps coming back\n","  no      = one-time episode, cleared and resolved\n","  unknown = not mentioned\"\"\"\n","\n","def build_prompt(row):\n","    caption    = str(row.get('caption', '')    or '')[:500]\n","    transcript = str(row.get('transcript', '') or '')[:1000]\n","    creator    = str(row.get('creator_type',   '') or '')\n","    bac        = str(row.get('before_after_claim', '') or '')\n","\n","    return f\"\"\"CREATOR TYPE: {creator}\n","BEFORE/AFTER CLAIM: {bac}\n","CAPTION: {caption}\n","TRANSCRIPT (first 1000 chars): {transcript}\n","\n","Classify this TikTok video. Return JSON with all 7 fields:\n","video_format, Video_type, face_visibility, indoor_outdoor,\n","condition_extent, condition_duration, condition_recurrence\"\"\"\n","\n","def validate_result(result):\n","    \"\"\"Ensure all values are within allowed taxonomy.\"\"\"\n","    validated = {}\n","    for col, allowed in TAXONOMY.items():\n","        val = result.get(col, DEFAULT_VALS[col])\n","        validated[col] = val if val in allowed else DEFAULT_VALS[col]\n","    return validated\n","\n","def classify_row(row, retries=2):\n","    for attempt in range(retries + 1):\n","        try:\n","            resp = client.messages.create(\n","                model='claude-haiku-4-5-20251001',\n","                max_tokens=150,\n","                system=SYSTEM_PROMPT,\n","                messages=[{'role': 'user', 'content': build_prompt(row)}]\n","            )\n","            text = resp.content[0].text.strip()\n","            # Strip markdown fences if present\n","            if text.startswith('```'):\n","                text = text.split('```')[1]\n","                if text.startswith('json'):\n","                    text = text[4:]\n","            result = json.loads(text)\n","            return validate_result(result)\n","        except anthropic.RateLimitError:\n","            print('Rate limit — waiting 60s...')\n","            time.sleep(60)\n","        except json.JSONDecodeError:\n","            if attempt < retries:\n","                time.sleep(1)\n","        except Exception:\n","            if attempt < retries:\n","                time.sleep(2)\n","    return DEFAULT_VALS.copy()\n","\n","# ── Resume from checkpoint ────────────────────────────────────────────\n","if os.path.exists(CKPT_VISUAL) and os.path.getsize(CKPT_VISUAL) > 10:\n","    ckpt_df   = pd.read_csv(CKPT_VISUAL, dtype=str)\n","    done_urls = set(ckpt_df['video_url'].tolist())\n","    results   = ckpt_df.to_dict('records')\n","    print(f'Resuming — {len(done_urls)} already classified')\n","else:\n","    done_urls, results = set(), []\n","\n","remaining = df[~df['video_url'].isin(done_urls)]\n","print(f'Classifying {len(remaining)} remaining videos...')\n","print(f'Estimated cost: ~${len(remaining) * 0.00015:.2f} (Haiku)\\n')\n","\n","# ── Classification loop ───────────────────────────────────────────────\n","for _, row in tqdm(remaining.iterrows(), total=len(remaining)):\n","    classification = classify_row(row)\n","    classification['video_url'] = row['video_url']\n","    results.append(classification)\n","    time.sleep(0.1)\n","\n","    # Checkpoint every 100\n","    if len(results) % 100 == 0:\n","        pd.DataFrame(results).to_csv(CKPT_VISUAL, index=False)\n","        print(f'  Checkpoint: {len(results)} classified')\n","\n","# Save final checkpoint\n","pd.DataFrame(results).to_csv(CKPT_VISUAL, index=False)\n","\n","# ── Merge back into main CSV ──────────────────────────────────────────\n","cls_df = pd.DataFrame(results).drop_duplicates(subset='video_url', keep='last')\n","\n","# Drop existing empty target cols before merge to avoid _x/_y suffixes\n","df = df.drop(columns=[c for c in TARGET_COLS if c in df.columns], errors='ignore')\n","df = df.merge(cls_df[['video_url'] + TARGET_COLS], on='video_url', how='left')\n","\n","# Fill any unmerged rows with defaults\n","for col, default in DEFAULT_VALS.items():\n","    df[col] = df[col].fillna(default)\n","\n","df.to_csv(CSV_VISUAL, index=False)\n","\n","# ── Summary ───────────────────────────────────────────────────────────\n","print('\\n' + '='*55)\n","print('VISUAL CLASSIFICATION COMPLETE')\n","print('='*55)\n","print(f'Output: {CSV_VISUAL}')\n","print()\n","for col in TARGET_COLS:\n","    print(f'\\n{col.upper()}:')\n","    print(df[col].value_counts().to_string())\n","\n","print(f'\\n✅ Saved → {CSV_VISUAL}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nNRjGpYRxsP4","executionInfo":{"status":"ok","timestamp":1776972808185,"user_tz":300,"elapsed":820658,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"a7033141-f70e-47b1-a7b8-e7c375cc6597"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Loaded: 731 rows\n","   Transcript coverage: 676/731\n","Classifying 731 remaining videos...\n","Estimated cost: ~$0.11 (Haiku)\n","\n"]},{"output_type":"stream","name":"stderr","text":[" 14%|█▎        | 100/731 [01:46<10:42,  1.02s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 100 classified\n"]},{"output_type":"stream","name":"stderr","text":[" 27%|██▋       | 200/731 [03:45<09:10,  1.04s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 200 classified\n"]},{"output_type":"stream","name":"stderr","text":[" 41%|████      | 300/731 [05:35<10:23,  1.45s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 300 classified\n"]},{"output_type":"stream","name":"stderr","text":[" 55%|█████▍    | 400/731 [07:21<06:59,  1.27s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 400 classified\n"]},{"output_type":"stream","name":"stderr","text":[" 68%|██████▊   | 500/731 [09:12<04:01,  1.05s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 500 classified\n"]},{"output_type":"stream","name":"stderr","text":[" 82%|████████▏ | 600/731 [11:01<02:14,  1.03s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 600 classified\n"]},{"output_type":"stream","name":"stderr","text":[" 96%|█████████▌| 700/731 [13:02<00:37,  1.22s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 700 classified\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 731/731 [13:39<00:00,  1.12s/it]"]},{"output_type":"stream","name":"stdout","text":["\n","=======================================================\n","VISUAL CLASSIFICATION COMPLETE\n","=======================================================\n","Output: /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Visual_Classified.csv\n","\n","\n","VIDEO_FORMAT:\n","video_format\n","talking_head    284\n","tutorial        158\n","demo            115\n","before_after     82\n","other            54\n","reaction         38\n","\n","VIDEO_TYPE:\n","Video_type\n","self_made       648\n","professional     69\n","duet             10\n","stitch            4\n","\n","FACE_VISIBILITY:\n","face_visibility\n","yes        389\n","unknown    208\n","no          90\n","partial     44\n","\n","INDOOR_OUTDOOR:\n","indoor_outdoor\n","indoor     441\n","unknown    276\n","both         9\n","outdoor      5\n","\n","CONDITION_EXTENT:\n","condition_extent\n","unknown          364\n","face_only        307\n","face_and_body     36\n","body_only         24\n","\n","CONDITION_DURATION:\n","condition_duration\n","unknown    618\n","years       65\n","months      25\n","days        20\n","weeks        3\n","\n","CONDITION_RECURRENCE:\n","condition_recurrence\n","unknown    479\n","yes        246\n","no           6\n","\n","✅ Saved → /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Visual_Classified.csv\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["# ── MERGE existing follower checkpoint into Visual Classified CSV ─────\n","import pandas as pd, os\n","\n","CSV_VISUAL   = f'{DATA_DIR}/TikTok_Acne_Visual_Classified.csv'\n","CKPT_FOLLOWERS = f'{DATA_DIR}/ckpt_followers.csv'\n","\n","if not os.path.exists(CKPT_FOLLOWERS):\n","    print('❌ ckpt_followers.csv not found — need to re-run Apify for followers')\n","else:\n","    df       = pd.read_csv(CSV_VISUAL, dtype=str)\n","    fol_df   = pd.read_csv(CKPT_FOLLOWERS, dtype=str)\n","    fol_df   = fol_df.drop_duplicates(subset='video_url', keep='last')\n","\n","    follower_map            = fol_df.set_index('video_url')['creator_followers']\n","    df['creator_followers'] = df['video_url'].map(follower_map).fillna('0')\n","\n","    df.to_csv(CSV_VISUAL, index=False)\n","\n","    ok = (pd.to_numeric(df['creator_followers'], errors='coerce') > 0).sum()\n","    print(f'✅ Merged: {ok}/731 videos now have follower count')\n","    print(f'   Saved → {CSV_VISUAL}')"],"metadata":{"id":"ylLdJRWF2skJ","executionInfo":{"status":"ok","timestamp":1776973175442,"user_tz":300,"elapsed":880,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"b265d5e4-f923-4544-eba6-5e724d1766f1","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Merged: 399/731 videos now have follower count\n","   Saved → /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Visual_Classified.csv\n"]}]},{"cell_type":"markdown","source":["Video ANalytics"],"metadata":{"id":"Njq-gKPKaJXf"}},{"cell_type":"code","execution_count":5,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"cx4rQ5muXmgg","executionInfo":{"status":"ok","timestamp":1777049411325,"user_tz":300,"elapsed":1133,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"20801184-7847-4d20-e3b1-947e92354a83"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Claude API connected: OK\n","✅ ffmpeg ready\n","✅ Loaded 731 rows\n","✅ Found 712 video files\n","✅ Matched 712/731 videos to files\n","Resuming — 731 already done\n","\n","Remaining: 0 total\n","  With video file:    0\n","  No video (default): 0\n","\n","Estimated time: ~0 mins at 15 RPM\n","Estimated cost: ~$0.00 (Claude Haiku vision)\n","\n"]},{"output_type":"stream","name":"stderr","text":["0it [00:00, ?it/s]"]},{"output_type":"stream","name":"stdout","text":["\n","Building final dataset...\n","\n","=======================================================\n","VIDEO ANALYTICS COMPLETE\n","=======================================================\n","Rows: 731 | Columns: 52\n","Saved → /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Video_Analytics.csv\n","\n","  Language                       731/731 non-unknown\n","  video_shot_complexity          731/731 non-unknown\n","  No._people_video               731/731 non-unknown\n","  creator_gender                 678/731 non-unknown\n","  creator_age_range              679/731 non-unknown\n","  creator_race_visual            665/731 non-unknown\n","  video_format                   731/731 non-unknown\n","  Video_type                     731/731 non-unknown\n","  face_visibility                705/731 non-unknown\n","  skin_condition_type            673/731 non-unknown\n","  before_after_claim             731/731 non-unknown\n","  sponsored_content              731/731 non-unknown\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}],"source":["# ── VIDEO ANALYTICS: Extract features from video frames (FREE) ────────\n","# Uses Claude Haiku vision on extracted frames to classify:\n","#   VISUAL:   video_shot_complexity, No._people_video, face_visibility\n","#             indoor_outdoor, creator_gender, creator_age_range\n","#             creator_race_visual, video_format, Video_type\n","#   CONTENT:  skin_condition_type, condition_extent, before_after_claim\n","#             treatment_type, product_name, product_brand\n","#             sponsored_content, promotion_style\n","#   LANGUAGE: Language (langdetect on caption — free, no API)\n","#\n","# FREE TIER LIMITS: 1500 requests/day, 15 RPM\n","# At 15 RPM: 731 videos ≈ 49 mins total\n","#\n","# Input:  CSV_FINAL + videos at VIDEO_DIR\n","# Output: TikTok_Acne_Video_Analytics.csv\n","#\n","# Setup: get free API key at aistudio.google.com\n","\n","import os, json, time, base64, io, subprocess, tempfile\n","import pandas as pd\n","from tqdm import tqdm\n","\n","# ── Install dependencies ──────────────────────────────────────────────\n","import anthropic\n","\n","try:\n","    from PIL import Image\n","except ImportError:\n","    subprocess.run(['pip', 'install', 'Pillow', '-q'])\n","    from PIL import Image\n","\n","try:\n","    from langdetect import detect, LangDetectException\n","except ImportError:\n","    subprocess.run(['pip', 'install', 'langdetect', '-q'])\n","    from langdetect import detect, LangDetectException\n","\n","# ── Config ────────────────────────────────────────────────────────────\n","VIDEO_DIR       = '/content/drive/MyDrive/TikTok_Acne_Research/videos/'\n","CSV_ANALYTICS   = f'{DATA_DIR}/TikTok_Acne_Video_Analytics.csv'\n","CKPT_ANALYTICS  = f'{DATA_DIR}/ckpt_video_analytics.csv'\n","FRAMES_PER_VID  = 3       # extract 3 frames: 10%, 50%, 90% of duration\n","MAX_FRAME_PX    = 1024    # 1024px — needed for text readability\n","SLEEP_BETWEEN   = 4.5     # seconds — keeps under 15 RPM free tier limit\n","\n","# ── Verify ────────────────────────────────────────────────────────────\n","# ⚠️  NEVER paste your real API key here if sharing this file\n","# Use environment variable instead:\n","if ANTHROPIC_API_KEY == 'sk-ant-YOUR_KEY_HERE':\n","    raise ValueError('Paste your Anthropic API key in Cell 3 first.')\n","\n","client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","\n","# Quick connection test\n","try:\n","    test = client.messages.create(\n","        model='claude-haiku-4-5-20251001',\n","        max_tokens=10,\n","        messages=[{'role': 'user', 'content': 'Reply with just: OK'}]\n","    )\n","    print(f'✅ Claude API connected: {test.content[0].text.strip()}')\n","except Exception as e:\n","    raise ValueError(f'Claude API error: {e}')\n","# Check ffmpeg\n","r = subprocess.run(['ffmpeg', '-version'], capture_output=True)\n","if r.returncode != 0:\n","    subprocess.run(['apt-get', 'install', '-y', 'ffmpeg'], capture_output=True)\n","print('✅ ffmpeg ready')\n","\n","# ── Load dataset ──────────────────────────────────────────────────────\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","df['video_id_clean'] = df['video_url'].str.extract(r'/video/(\\d+)')\n","print(f'✅ Loaded {len(df)} rows')\n","\n","# Map video files\n","video_files = {}\n","if os.path.exists(VIDEO_DIR):\n","    for f in os.listdir(VIDEO_DIR):\n","        if f.endswith('.mp4'):\n","            vid_id = f.replace('.mp4', '').replace('tiktok_', '').replace('video_', '')\n","            video_files[vid_id] = os.path.join(VIDEO_DIR, f)\n","    print(f'✅ Found {len(video_files)} video files')\n","else:\n","    raise FileNotFoundError(\n","        f'VIDEO_DIR not found: {VIDEO_DIR}\\n'\n","        'Update VIDEO_DIR to point to your videos folder.'\n","    )\n","\n","df['video_path'] = df['video_id_clean'].map(video_files)\n","matched = df['video_path'].notna().sum()\n","print(f'✅ Matched {matched}/{len(df)} videos to files')\n","\n","# ── Language detection (free, no API) ─────────────────────────────────\n","def detect_language(text):\n","    try:\n","        if not text or str(text).strip() in ('', 'nan'):\n","            return 'unknown'\n","        return detect(str(text)[:500])\n","    except Exception:\n","        return 'unknown'\n","\n","# ── Frame extraction ──────────────────────────────────────────────────\n","def extract_frames(video_path, n_frames=3):\n","    \"\"\"Extract n evenly-spaced frames. Returns list of PIL Images.\"\"\"\n","    frames = []\n","    try:\n","        # Get duration\n","        dur_cmd = [\n","            'ffprobe', '-v', 'error', '-show_entries', 'format=duration',\n","            '-of', 'default=noprint_wrappers=1:nokey=1', video_path\n","        ]\n","        dur_r = subprocess.run(dur_cmd, capture_output=True, text=True, timeout=10)\n","        duration = float(dur_r.stdout.strip())\n","        if duration <= 0:\n","            return []\n","\n","        with tempfile.TemporaryDirectory() as tmpdir:\n","            for i, pct in enumerate([0.1, 0.5, 0.9][:n_frames]):\n","                ts = max(0.1, duration * pct)\n","                out_path = os.path.join(tmpdir, f'frame_{i}.jpg')\n","                cmd = [\n","                    'ffmpeg', '-ss', str(ts), '-i', video_path,\n","                    '-vframes', '1',\n","                    '-vf', f'scale={MAX_FRAME_PX}:-1',\n","                    '-q:v', '2', out_path, '-y', '-loglevel', 'error'\n","                ]\n","                subprocess.run(cmd, capture_output=True, timeout=15)\n","                if os.path.exists(out_path) and os.path.getsize(out_path) > 0:\n","                    frames.append(Image.open(out_path).copy())\n","    except Exception:\n","        pass\n","    return frames\n","\n","# ── Claude Haiku prompt ─────────────────────────────────────────────\n","PROMPT_TEMPLATE = \"\"\"You are a content analyst classifying TikTok skincare/acne videos for academic research.\n","Analyze the provided video frames and caption carefully.\n","\n","VIDEO CAPTION: {caption}\n","\n","Return ONLY a valid JSON object with exactly these fields (no markdown, no explanation):\n","\n","{{\n","  \"video_shot_complexity\": <1|2|3|4>,\n","  \"No._people_video\": <integer>,\n","  \"face_visibility\": <\"yes\"|\"no\"|\"partial\">,\n","  \"indoor_outdoor\": <\"indoor\"|\"outdoor\"|\"both\"|\"unknown\">,\n","  \"creator_gender\": <\"male\"|\"female\"|\"unknown\">,\n","  \"creator_age_range\": <\"18-25\"|\"26-35\"|\"36-50\"|\"50+\"|\"unknown\">,\n","  \"creator_race_visual\": <\"white\"|\"black\"|\"asian\"|\"hispanic\"|\"south_asian\"|\"middle_eastern\"|\"mixed\"|\"unknown\">,\n","  \"video_format\": <\"demo\"|\"reaction\"|\"tutorial\"|\"talking_head\"|\"before_after\"|\"other\">,\n","  \"Video_type\": <\"self_made\"|\"professional\"|\"duet\"|\"stitch\">,\n","  \"skin_condition_type\": <\"acne\"|\"rosacea\"|\"eczema\"|\"hyperpigmentation\"|\"general_skincare\"|\"other\"|\"unknown\">,\n","  \"condition_extent\": <\"face_only\"|\"face_and_body\"|\"body_only\"|\"unknown\">,\n","  \"before_after_claim\": <\"yes\"|\"no\">,\n","  \"treatment_type\": <\"topical\"|\"oral\"|\"dietary\"|\"device\"|\"procedure\"|\"supplement\"|\"lifestyle\"|\"none\"|\"unknown\">,\n","  \"product_name\": <string or null>,\n","  \"product_brand\": <string or null>,\n","  \"sponsored_content\": <\"yes\"|\"no\"|\"unclear\">,\n","  \"promotion_style\": <\"organic\"|\"paid_partnership\"|\"affiliate\"|\"none\"|\"unclear\">\n","}}\n","\n","DEFINITIONS:\n","video_shot_complexity: 1=simple selfie/handheld, 2=basic stable, 3=multiple angles/cuts, 4=studio/professional lighting\n","No._people_video: total people visible across all frames (0 if none)\n","face_visibility: is the creator face clearly shown\n","indoor_outdoor: filming location based on background\n","creator_gender: perceived gender of main speaker/creator\n","creator_age_range: estimated age bracket of main creator\n","creator_race_visual: perceived race/ethnicity (for academic research only)\n","video_format: demo=product application shown, reaction=reacting to content, tutorial=step-by-step how-to, talking_head=speaking to camera, before_after=transformation shown, other\n","Video_type: self_made=casual/bedroom, professional=studio/branded, duet=split screen TikTok duet, stitch=TikTok stitch format\n","product_name: exact product name if visible/mentioned (null if none)\n","product_brand: brand name if visible/mentioned (null if none)\n","sponsored_content: is this paid/sponsored based on disclosure text or context\n","promotion_style: how promotion is done\"\"\"\n","\n","# ── Validation ────────────────────────────────────────────────────────\n","VALID = {\n","    'video_shot_complexity':  [1, 2, 3, 4],\n","    'face_visibility':        ['yes', 'no', 'partial'],\n","    'indoor_outdoor':         ['indoor', 'outdoor', 'both', 'unknown'],\n","    'creator_gender':         ['male', 'female', 'unknown'],\n","    'creator_age_range':      ['18-25', '26-35', '36-50', '50+', 'unknown'],\n","    'creator_race_visual':    ['white', 'black', 'asian', 'hispanic', 'south_asian',\n","                               'middle_eastern', 'mixed', 'unknown'],\n","    'video_format':           ['demo', 'reaction', 'tutorial', 'talking_head',\n","                               'before_after', 'other'],\n","    'Video_type':             ['self_made', 'professional', 'duet', 'stitch'],\n","    'skin_condition_type':    ['acne', 'rosacea', 'eczema', 'hyperpigmentation',\n","                               'general_skincare', 'other', 'unknown'],\n","    'condition_extent':       ['face_only', 'face_and_body', 'body_only', 'unknown'],\n","    'before_after_claim':     ['yes', 'no'],\n","    'treatment_type':         ['topical', 'oral', 'dietary', 'device', 'procedure',\n","                               'supplement', 'lifestyle', 'none', 'unknown'],\n","    'sponsored_content':      ['yes', 'no', 'unclear'],\n","    'promotion_style':        ['organic', 'paid_partnership', 'affiliate', 'none', 'unclear'],\n","}\n","\n","DEFAULTS = {\n","    'video_shot_complexity': 1,  'No._people_video': 1,\n","    'face_visibility': 'unknown', 'indoor_outdoor': 'unknown',\n","    'creator_gender': 'unknown',  'creator_age_range': 'unknown',\n","    'creator_race_visual': 'unknown', 'video_format': 'other',\n","    'Video_type': 'self_made',    'skin_condition_type': 'unknown',\n","    'condition_extent': 'unknown', 'before_after_claim': 'no',\n","    'treatment_type': 'unknown',   'product_name': None,\n","    'product_brand': None,         'sponsored_content': 'unclear',\n","    'promotion_style': 'unclear',\n","}\n","\n","def validate(result):\n","    out = {}\n","    for col, allowed in VALID.items():\n","        val = result.get(col, DEFAULTS[col])\n","        out[col] = val if val in allowed else DEFAULTS[col]\n","    # People count — safe int conversion\n","    try:\n","        out['No._people_video'] = max(0, int(result.get('No._people_video') or 0))\n","    except Exception:\n","        out['No._people_video'] = 0\n","    # String or None fields\n","    out['product_name']  = str(result['product_name']).strip()  if result.get('product_name')  else None\n","    out['product_brand'] = str(result['product_brand']).strip() if result.get('product_brand') else None\n","    return out\n","\n","def classify_video(frames, caption, retries=2):\n","    \"\"\"Send frames + caption to Claude Haiku, return validated dict.\"\"\"\n","    if not frames:\n","        return DEFAULTS.copy()\n","\n","    prompt = PROMPT_TEMPLATE.format(caption=str(caption)[:400])\n","\n","    # Build Claude content blocks: images then text\n","    content = []\n","    for img in frames:\n","        # Convert PIL Image to base64 JPEG\n","        buf = io.BytesIO()\n","        img.convert('RGB').save(buf, format='JPEG', quality=85)\n","        b64 = base64.standard_b64encode(buf.getvalue()).decode('utf-8')\n","        content.append({\n","            'type': 'image',\n","            'source': {'type': 'base64', 'media_type': 'image/jpeg', 'data': b64}\n","        })\n","    content.append({'type': 'text', 'text': prompt})\n","\n","    for attempt in range(retries + 1):\n","        try:\n","            response = client.messages.create(\n","                model='claude-haiku-4-5-20251001',\n","                max_tokens=400,\n","                system='You are a content analyst. Return ONLY valid JSON. No markdown, no explanation.',\n","                messages=[{'role': 'user', 'content': content}]\n","            )\n","            text = response.content[0].text.strip()\n","            if '```' in text:\n","                parts = text.split('```')\n","                for part in parts:\n","                    p = part.strip()\n","                    if p.startswith('json'): p = p[4:].strip()\n","                    if p.startswith('{'):\n","                        text = p\n","                        break\n","            result = json.loads(text)\n","            return validate(result)\n","\n","        except anthropic.RateLimitError:\n","            print('\\n  Rate limit — waiting 60s...')\n","            time.sleep(60)\n","        except json.JSONDecodeError:\n","            if attempt < retries: time.sleep(2)\n","        except Exception:\n","            if attempt < retries: time.sleep(3)\n","\n","    return DEFAULTS.copy()\n","\n","# ── Resume from checkpoint ────────────────────────────────────────────\n","if os.path.exists(CKPT_ANALYTICS) and os.path.getsize(CKPT_ANALYTICS) > 10:\n","    ckpt_df   = pd.read_csv(CKPT_ANALYTICS, dtype=str)\n","    done_urls = set(ckpt_df['video_url'].tolist())\n","    results   = ckpt_df.to_dict('records')\n","    print(f'Resuming — {len(done_urls)} already done')\n","else:\n","    done_urls, results = set(), []\n","\n","remaining  = df[~df['video_url'].isin(done_urls)]\n","no_video   = remaining['video_path'].isna().sum()\n","has_video  = len(remaining) - no_video\n","print(f'\\nRemaining: {len(remaining)} total')\n","print(f'  With video file:    {has_video}')\n","print(f'  No video (default): {no_video}')\n","print(f'\\nEstimated time: ~{has_video * SLEEP_BETWEEN / 60:.0f} mins at 15 RPM')\n","print(f'Estimated cost: ~${len(remaining) * 0.002:.2f} (Claude Haiku vision)\\n')\n","\n","# ── Main loop ─────────────────────────────────────────────────────────\n","for _, row in tqdm(remaining.iterrows(), total=len(remaining)):\n","    video_url  = row['video_url']\n","    video_path = row.get('video_path')\n","    caption    = str(row.get('caption', '') or '')\n","    video_id   = str(row.get('video_id_clean', '') or '')\n","\n","    # Language from caption — always free\n","    language = detect_language(caption)\n","\n","    record = {\n","        'video_url': video_url,\n","        'video_id':  video_id,\n","        'Language':  language,\n","    }\n","\n","    if pd.notna(video_path) and os.path.exists(str(video_path)):\n","        frames = extract_frames(str(video_path), FRAMES_PER_VID)\n","        if frames:\n","            vision_result = classify_video(frames, caption)\n","            record.update(vision_result)\n","        else:\n","            record.update(DEFAULTS.copy())\n","    else:\n","        record.update(DEFAULTS.copy())\n","\n","    results.append(record)\n","    time.sleep(SLEEP_BETWEEN)\n","\n","    # Checkpoint every 50\n","    if len(results) % 50 == 0:\n","        pd.DataFrame(results).to_csv(CKPT_ANALYTICS, index=False)\n","        print(f'\\n  Checkpoint: {len(results)} done')\n","\n","pd.DataFrame(results).to_csv(CKPT_ANALYTICS, index=False)\n","\n","# ── Build final dataset ───────────────────────────────────────────────\n","print('\\nBuilding final dataset...')\n","analytics_df = pd.DataFrame(results).drop_duplicates(subset='video_url', keep='last')\n","\n","base_df = pd.read_csv(CSV_FINAL, dtype=str)\n","\n","# Drop columns that video analytics replaces\n","replace_cols = list(DEFAULTS.keys()) + ['Language']\n","base_df = base_df.drop(\n","    columns=[c for c in replace_cols if c in base_df.columns],\n","    errors='ignore'\n",")\n","\n","final_df = base_df.merge(analytics_df, on='video_url', how='left')\n","\n","# Fill unmatched rows with defaults\n","for col, default in DEFAULTS.items():\n","    if col in final_df.columns:\n","        final_df[col] = final_df[col].fillna(\n","            '' if default is None else str(default)\n","        )\n","if 'Language' in final_df.columns:\n","    final_df['Language'] = final_df['Language'].fillna('unknown')\n","\n","final_df.to_csv(CSV_ANALYTICS, index=False)\n","\n","# ── Summary ───────────────────────────────────────────────────────────\n","print('\\n' + '='*55)\n","print('VIDEO ANALYTICS COMPLETE')\n","print('='*55)\n","print(f'Rows: {len(final_df)} | Columns: {len(final_df.columns)}')\n","print(f'Saved → {CSV_ANALYTICS}')\n","print()\n","\n","key_cols = [\n","    'Language', 'video_shot_complexity', 'No._people_video',\n","    'creator_gender', 'creator_age_range', 'creator_race_visual',\n","    'video_format', 'Video_type', 'face_visibility',\n","    'skin_condition_type', 'before_after_claim', 'sponsored_content'\n","]\n","for col in key_cols:\n","    if col in final_df.columns:\n","        valid = (\n","            final_df[col].notna() &\n","            (final_df[col].astype(str).str.strip() != '') &\n","            (final_df[col].astype(str).str.strip() != 'None') &\n","            (final_df[col].astype(str).str.strip() != 'unknown')\n","        ).sum()\n","        print(f'  {col:<30} {valid}/{len(final_df)} non-unknown')"]},{"cell_type":"code","source":["import pandas as pd\n","\n","df = pd.read_csv('/content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Video_Analytics.csv', dtype=str)\n","\n","cols = ['video_shot_complexity', 'before_after_claim', 'creator_gender',\n","        'creator_age_range', 'sponsored_content', 'video_format',\n","        'skin_condition_type', 'Language']\n","\n","for col in cols:\n","    print(f'\\n{col}:')\n","    print(df[col].value_counts().to_string())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"O3NNSlSeZ7wj","executionInfo":{"status":"ok","timestamp":1777049520220,"user_tz":300,"elapsed":183,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"081801eb-34dc-4ebf-e008-7de6ff9ffdbc"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","video_shot_complexity:\n","video_shot_complexity\n","2    385\n","3    303\n","1     38\n","4      5\n","\n","before_after_claim:\n","before_after_claim\n","no     491\n","yes    240\n","\n","creator_gender:\n","creator_gender\n","female     520\n","male       158\n","unknown     53\n","\n","creator_age_range:\n","creator_age_range\n","18-25      355\n","26-35      278\n","unknown     52\n","36-50       41\n","50+          5\n","\n","sponsored_content:\n","sponsored_content\n","no         374\n","unclear    248\n","yes        109\n","\n","video_format:\n","video_format\n","talking_head    279\n","tutorial        140\n","demo            131\n","before_after    120\n","reaction         31\n","other            30\n","\n","skin_condition_type:\n","skin_condition_type\n","acne                 355\n","general_skincare     243\n","unknown               58\n","hyperpigmentation     40\n","other                 31\n","rosacea                3\n","eczema                 1\n","\n","Language:\n","Language\n","en    668\n","no     12\n","sk      7\n","ro      6\n","fr      6\n","da      6\n","sv      4\n","nl      2\n","ca      2\n","es      2\n","fi      2\n","de      2\n","it      2\n","id      2\n","et      1\n","vi      1\n","tr      1\n","sl      1\n","ar      1\n","lt      1\n","pt      1\n","cy      1\n"]}]},{"cell_type":"code","source":["# ── FINALIZE DATASET: 3 fixes in one cell ────────────────────────────\n","# Fix 1: creator_followers — merge from checkpoint\n","# Fix 2: condition_duration — NLP from transcript/caption\n","# Fix 3: condition_recurrence — NLP from transcript/caption\n","#\n","# Input:  TikTok_Acne_Video_Analytics.csv + ckpt_followers.csv\n","# Output: TikTok_Acne_FINAL.csv\n","\n","import os, json, time, pandas as pd, anthropic\n","from tqdm import tqdm\n","\n","# ── Config ────────────────────────────────────────────────────────────\n","CSV_INPUT    = f'{DATA_DIR}/TikTok_Acne_Video_Analytics.csv'\n","CSV_OUTPUT   = f'{DATA_DIR}/TikTok_Acne_FINAL.csv'\n","CKPT_FOLLOW  = f'{DATA_DIR}/ckpt_followers.csv'\n","CKPT_NLP     = f'{DATA_DIR}/ckpt_condition_nlp.csv'\n","\n","if ANTHROPIC_API_KEY == 'sk-ant-YOUR_KEY_HERE':\n","    raise ValueError('Paste your Anthropic API key in Cell 3 first.')\n","\n","client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","df     = pd.read_csv(CSV_INPUT, dtype=str)\n","print(f'✅ Loaded: {len(df)} rows × {len(df.columns)} columns')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# FIX 1: creator_followers — merge from checkpoint\n","# ═══════════════════════════════════════════════════════════════════════\n","print('\\n── Fix 1: creator_followers ─────────────────────────────────────')\n","if os.path.exists(CKPT_FOLLOW) and os.path.getsize(CKPT_FOLLOW) > 10:\n","    fol_df       = pd.read_csv(CKPT_FOLLOW, dtype=str)\n","    fol_df       = fol_df.drop_duplicates(subset='video_url', keep='last')\n","    follower_map = fol_df.set_index('video_url')['creator_followers']\n","    df['creator_followers'] = df['video_url'].map(follower_map).fillna('0')\n","    ok = (pd.to_numeric(df['creator_followers'], errors='coerce') > 0).sum()\n","    print(f'✅ creator_followers > 0: {ok}/731')\n","else:\n","    print('⚠️  ckpt_followers.csv not found — creator_followers stays 0')\n","    print(f'   Expected at: {CKPT_FOLLOW}')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# FIX 2 + 3: condition_duration + condition_recurrence via Claude Haiku\n","# ═══════════════════════════════════════════════════════════════════════\n","print('\\n── Fix 2+3: condition_duration + condition_recurrence ───────────')\n","\n","SYSTEM = \"\"\"You are classifying TikTok acne/skincare videos for academic research.\n","Given the transcript and caption, classify two fields about the skin condition being discussed.\n","Respond ONLY with a valid JSON object. No markdown, no explanation.\"\"\"\n","\n","PROMPT = \"\"\"CAPTION: {caption}\n","TRANSCRIPT: {transcript}\n","\n","Classify these two fields about the skin condition discussed in this video:\n","\n","{{\n","  \"condition_duration\": \"<days|weeks|months|years|unknown>\",\n","  \"condition_recurrence\": \"<yes|no|unknown>\"\n","}}\n","\n","DEFINITIONS:\n","condition_duration: How long has the creator/subject had the condition?\n","  days    = very recent, just happened, overnight\n","  weeks   = a few weeks\n","  months  = several months\n","  years   = years, long-term, since teen years, chronic, since high school\n","  unknown = not mentioned at all\n","\n","condition_recurrence: Does the condition keep coming back?\n","  yes     = recurring, chronic, hormonal, keeps coming back, flares up, again\n","  no      = one-time, cleared and done, resolved\n","  unknown = not mentioned\"\"\"\n","\n","VALID_DUR  = {'days', 'weeks', 'months', 'years', 'unknown'}\n","VALID_REC  = {'yes', 'no', 'unknown'}\n","DEFAULT    = {'condition_duration': 'unknown', 'condition_recurrence': 'unknown'}\n","\n","def classify_condition(caption, transcript, retries=2):\n","    cap   = str(caption   or '')[:400]\n","    trans = str(transcript or '')[:800]\n","\n","    # Fast rule-based pass first — saves API calls\n","    combined = (cap + ' ' + trans).lower()\n","\n","    dur_result = 'unknown'\n","    if any(w in combined for w in ['year', 'years', 'since high school', 'since teen',\n","                                    'chronic', 'long time', 'forever', 'always had']):\n","        dur_result = 'years'\n","    elif any(w in combined for w in ['month', 'months']):\n","        dur_result = 'months'\n","    elif any(w in combined for w in ['week', 'weeks']):\n","        dur_result = 'weeks'\n","    elif any(w in combined for w in ['overnight', 'yesterday', 'today', 'just got',\n","                                      'literally overnight', 'sudden']):\n","        dur_result = 'days'\n","\n","    rec_result = 'unknown'\n","    if any(w in combined for w in ['keep coming back', 'keeps coming back', 'recurring',\n","                                    'hormonal', 'flares', 'flare up', 'again and again',\n","                                    'chronic', 'always breaking out', 'every month']):\n","        rec_result = 'yes'\n","    elif any(w in combined for w in ['cleared', 'gone', 'resolved', 'fixed', 'cured',\n","                                      'never came back', 'one time']):\n","        rec_result = 'no'\n","\n","    # If both filled by rules, skip API\n","    if dur_result != 'unknown' and rec_result != 'unknown':\n","        return {'condition_duration': dur_result, 'condition_recurrence': rec_result}\n","\n","    # Otherwise use Claude for ambiguous cases\n","    for attempt in range(retries + 1):\n","        try:\n","            resp = client.messages.create(\n","                model='claude-haiku-4-5-20251001',\n","                max_tokens=60,\n","                system=SYSTEM,\n","                messages=[{'role': 'user', 'content':\n","                    PROMPT.format(caption=cap, transcript=trans)}]\n","            )\n","            text = resp.content[0].text.strip()\n","            if text.startswith('```'):\n","                text = text.split('```')[1]\n","                if text.startswith('json'): text = text[4:]\n","            result = json.loads(text)\n","\n","            # Use API result but keep rule-based values if already found\n","            final_dur = dur_result if dur_result != 'unknown' else (\n","                result.get('condition_duration', 'unknown')\n","                if result.get('condition_duration') in VALID_DUR else 'unknown'\n","            )\n","            final_rec = rec_result if rec_result != 'unknown' else (\n","                result.get('condition_recurrence', 'unknown')\n","                if result.get('condition_recurrence') in VALID_REC else 'unknown'\n","            )\n","            return {'condition_duration': final_dur, 'condition_recurrence': final_rec}\n","\n","        except anthropic.RateLimitError:\n","            print('\\nRate limit — waiting 60s...')\n","            time.sleep(60)\n","        except json.JSONDecodeError:\n","            if attempt < retries: time.sleep(1)\n","        except Exception:\n","            if attempt < retries: time.sleep(2)\n","\n","    # Fallback: return whatever rules found\n","    return {'condition_duration': dur_result, 'condition_recurrence': rec_result}\n","\n","# Resume from checkpoint\n","if os.path.exists(CKPT_NLP) and os.path.getsize(CKPT_NLP) > 10:\n","    ckpt_df   = pd.read_csv(CKPT_NLP, dtype=str)\n","    done_urls = set(ckpt_df['video_url'].tolist())\n","    results   = ckpt_df.to_dict('records')\n","    print(f'Resuming — {len(done_urls)} already done')\n","else:\n","    done_urls, results = set(), []\n","\n","remaining = df[~df['video_url'].isin(done_urls)]\n","print(f'To classify: {len(remaining)} rows')\n","\n","# Estimate API calls needed (rule-based handles ~40%)\n","est_api = int(len(remaining) * 0.6)\n","print(f'Estimated API calls: ~{est_api} | Cost: ~${est_api * 0.00003:.3f}\\n')\n","\n","for _, row in tqdm(remaining.iterrows(), total=len(remaining)):\n","    cap   = row.get('caption', '')   or ''\n","    trans = row.get('transcript', '') or ''\n","    res   = classify_condition(cap, trans)\n","    res['video_url'] = row['video_url']\n","    results.append(res)\n","    time.sleep(0.05)\n","\n","    if len(results) % 100 == 0:\n","        pd.DataFrame(results).to_csv(CKPT_NLP, index=False)\n","        print(f'  Checkpoint: {len(results)}')\n","\n","pd.DataFrame(results).to_csv(CKPT_NLP, index=False)\n","\n","# Merge back\n","nlp_df = pd.DataFrame(results).drop_duplicates(subset='video_url', keep='last')\n","df     = df.drop(columns=['condition_duration', 'condition_recurrence'], errors='ignore')\n","df     = df.merge(nlp_df[['video_url', 'condition_duration', 'condition_recurrence']],\n","                  on='video_url', how='left')\n","df['condition_duration']   = df['condition_duration'].fillna('unknown')\n","df['condition_recurrence'] = df['condition_recurrence'].fillna('unknown')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# SAVE FINAL\n","# ═══════════════════════════════════════════════════════════════════════\n","df.to_csv(CSV_OUTPUT, index=False)\n","\n","print('\\n' + '='*55)\n","print('DATASET FINALIZED')\n","print('='*55)\n","print(f'Rows: {len(df)} | Columns: {len(df.columns)}')\n","print()\n","\n","# Report all three fixes\n","cf = (pd.to_numeric(df['creator_followers'], errors='coerce') > 0).sum()\n","print(f'  creator_followers > 0:   {cf}/731 ({cf/731*100:.1f}%)')\n","\n","for col in ['condition_duration', 'condition_recurrence']:\n","    vc = df[col].value_counts()\n","    known = 731 - vc.get('unknown', 0)\n","    print(f'  {col}: {known}/731 non-unknown')\n","    for val, cnt in vc.items():\n","        print(f'    {val:<12} {cnt}')\n","\n","print(f'\\nSaved → {CSV_OUTPUT}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"iUqSN1HobEdU","executionInfo":{"status":"ok","timestamp":1777050576108,"user_tz":300,"elapsed":757641,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"76c13586-330e-41a3-df9c-0f37574e6542"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Loaded: 731 rows × 52 columns\n","\n","── Fix 1: creator_followers ─────────────────────────────────────\n","✅ creator_followers > 0: 399/731\n","\n","── Fix 2+3: condition_duration + condition_recurrence ───────────\n","To classify: 731 rows\n","Estimated API calls: ~438 | Cost: ~$0.013\n","\n"]},{"output_type":"stream","name":"stderr","text":[" 14%|█▍        | 101/731 [01:08<02:47,  3.76it/s]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 100\n"]},{"output_type":"stream","name":"stderr","text":[" 27%|██▋       | 200/731 [02:31<12:05,  1.37s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 200\n"]},{"output_type":"stream","name":"stderr","text":[" 41%|████      | 300/731 [04:18<06:38,  1.08it/s]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 300\n"]},{"output_type":"stream","name":"stderr","text":[" 55%|█████▍    | 400/731 [06:10<07:05,  1.28s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 400\n"]},{"output_type":"stream","name":"stderr","text":[" 68%|██████▊   | 500/731 [08:05<04:29,  1.17s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 500\n"]},{"output_type":"stream","name":"stderr","text":[" 82%|████████▏ | 599/731 [10:03<02:56,  1.33s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 600\n"]},{"output_type":"stream","name":"stderr","text":[" 96%|█████████▌| 700/731 [11:58<00:32,  1.06s/it]"]},{"output_type":"stream","name":"stdout","text":["  Checkpoint: 700\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 731/731 [12:36<00:00,  1.03s/it]"]},{"output_type":"stream","name":"stdout","text":["\n","=======================================================\n","DATASET FINALIZED\n","=======================================================\n","Rows: 731 | Columns: 52\n","\n","  creator_followers > 0:   399/731 (54.6%)\n","  condition_duration: 302/731 non-unknown\n","    unknown      429\n","    years        153\n","    weeks        58\n","    days         57\n","    months       34\n","  condition_recurrence: 226/731 non-unknown\n","    unknown      505\n","    yes          204\n","    no           22\n","\n","Saved → /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_FINAL.csv\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["# ── PRODUCT EXTRACTION: product_name + product_brand from caption/transcript\n","# Uses Claude Haiku to extract product names and brands from text\n","# Only runs on rows where product_name is currently empty\n","#\n","# Input:  TikTok_Acne_FINAL.csv\n","# Output: TikTok_Acne_FINAL.csv (updated in place)\n","# Cost:   ~$0.02 for ~345 empty rows\n","\n","import os, json, time, pandas as pd, anthropic\n","from tqdm import tqdm\n","\n","# ── Config ────────────────────────────────────────────────────────────\n","CSV_PATH   = f'{DATA_DIR}/TikTok_Acne_FINAL.csv'\n","CKPT_PROD  = f'{DATA_DIR}/ckpt_product_extraction.csv'\n","\n","if ANTHROPIC_API_KEY == 'sk-ant-YOUR_KEY_HERE':\n","    raise ValueError('Paste your Anthropic API key in Cell 3 first.')\n","\n","client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","df     = pd.read_csv(CSV_PATH, dtype=str)\n","print(f'✅ Loaded: {len(df)} rows')\n","\n","# ── Identify rows needing extraction ─────────────────────────────────\n","def is_empty(val):\n","    return pd.isna(val) or str(val).strip() in ('', 'nan', 'None', 'none', 'null')\n","\n","needs_extraction = df['product_name'].apply(is_empty)\n","print(f'Rows with empty product_name: {needs_extraction.sum()}/731')\n","print(f'Already filled: {(~needs_extraction).sum()}/731')\n","\n","# ── Claude prompt ─────────────────────────────────────────────────────\n","SYSTEM = \"\"\"You are extracting product and brand mentions from TikTok skincare video text.\n","Respond ONLY with a valid JSON object. No markdown, no explanation.\"\"\"\n","\n","PROMPT = \"\"\"Extract any skincare/acne product names and brand names from this TikTok video text.\n","\n","CAPTION: {caption}\n","TRANSCRIPT: {transcript}\n","\n","Return JSON:\n","{{\n","  \"product_name\": <specific product name as string, or null if none mentioned>,\n","  \"product_brand\": <brand name as string, or null if none mentioned>\n","}}\n","\n","RULES:\n","- product_name: specific product (e.g. \"CeraVe Foaming Cleanser\", \"Differin Gel\", \"tretinoin 0.025%\")\n","- product_brand: brand only (e.g. \"CeraVe\", \"La Roche-Posay\", \"The Ordinary\")\n","- If multiple products mentioned, list the most prominently featured one\n","- Generic ingredients (salicylic acid, benzoyl peroxide) are NOT product names unless a specific branded product is named\n","- Prescription drug names count (tretinoin, spironolactone, accutane, doxycycline)\n","- null if no specific product or brand is mentioned\"\"\"\n","\n","def extract_products(caption, transcript, retries=2):\n","    cap   = str(caption   or '')[:500]\n","    trans = str(transcript or '')[:800]\n","    combined = (cap + ' ' + trans).lower()\n","\n","    # Fast rule-based check — skip API if no product signal at all\n","    product_signals = [\n","        'cerave', 'neutrogena', 'la roche', 'differin', 'tretinoin', 'accutane',\n","        'proactiv', 'paula', 'the ordinary', 'inkey list', 'cosrx', 'innisfree',\n","        'cetaphil', 'aveeno', 'adapalene', 'spironolactone', 'duac', 'epiduo',\n","        'clindamycin', 'doxycycline', 'minocycline', 'benzoyl peroxide', 'salicylic',\n","        'retinol', 'retinoid', 'niacinamide', 'hyaluronic', 'vitamin c serum',\n","        'sunscreen', 'spf', 'moisturizer', 'cleanser', 'toner', 'serum', 'cream',\n","        'gel', 'lotion', 'mask', 'peel', 'product', 'brand', 'routine',\n","        'skincare', 'use this', 'try this', 'recommend', 'favorite', 'holy grail',\n","        'changed my skin', 'cleared my skin', 'works for', 'helped my'\n","    ]\n","    has_signal = any(s in combined for s in product_signals)\n","\n","    if not has_signal:\n","        return {'product_name': None, 'product_brand': None}\n","\n","    for attempt in range(retries + 1):\n","        try:\n","            resp = client.messages.create(\n","                model='claude-haiku-4-5-20251001',\n","                max_tokens=80,\n","                system=SYSTEM,\n","                messages=[{'role': 'user', 'content':\n","                    PROMPT.format(caption=cap, transcript=trans)}]\n","            )\n","            text = resp.content[0].text.strip()\n","            if text.startswith('```'):\n","                text = text.split('```')[1]\n","                if text.startswith('json'): text = text[4:]\n","            result = json.loads(text)\n","            pname  = result.get('product_name')\n","            pbrand = result.get('product_brand')\n","            return {\n","                'product_name':  str(pname).strip()  if pname  and str(pname)  not in ('null','None','') else None,\n","                'product_brand': str(pbrand).strip() if pbrand and str(pbrand) not in ('null','None','') else None,\n","            }\n","        except anthropic.RateLimitError:\n","            print('\\nRate limit — waiting 60s...')\n","            time.sleep(60)\n","        except json.JSONDecodeError:\n","            if attempt < retries: time.sleep(1)\n","        except Exception:\n","            if attempt < retries: time.sleep(2)\n","\n","    return {'product_name': None, 'product_brand': None}\n","\n","# ── Resume from checkpoint ────────────────────────────────────────────\n","if os.path.exists(CKPT_PROD) and os.path.getsize(CKPT_PROD) > 10:\n","    ckpt_df   = pd.read_csv(CKPT_PROD, dtype=str)\n","    done_urls = set(ckpt_df['video_url'].tolist())\n","    results   = ckpt_df.to_dict('records')\n","    print(f'Resuming — {len(done_urls)} already done')\n","else:\n","    done_urls, results = set(), []\n","\n","# Only process rows with empty product_name\n","to_process = df[needs_extraction & ~df['video_url'].isin(done_urls)]\n","print(f'To process: {len(to_process)}')\n","print(f'Estimated cost: ~${len(to_process) * 0.00005:.3f}\\n')\n","\n","# ── Extraction loop ───────────────────────────────────────────────────\n","for _, row in tqdm(to_process.iterrows(), total=len(to_process)):\n","    cap   = row.get('caption', '')   or ''\n","    trans = row.get('transcript', '') or ''\n","    res   = extract_products(cap, trans)\n","    res['video_url'] = row['video_url']\n","    results.append(res)\n","    time.sleep(0.1)\n","\n","    if len(results) % 100 == 0:\n","        pd.DataFrame(results).to_csv(CKPT_PROD, index=False)\n","        print(f'  Checkpoint: {len(results)}')\n","\n","pd.DataFrame(results).to_csv(CKPT_PROD, index=False)\n","\n","# ── Merge back — only update empty rows ──────────────────────────────\n","ext_df = pd.DataFrame(results).drop_duplicates(subset='video_url', keep='last')\n","ext_df = ext_df[ext_df['video_url'].isin(df[needs_extraction]['video_url'])]\n","\n","# Map extracted values only to empty rows\n","pname_map  = ext_df.set_index('video_url')['product_name']\n","pbrand_map = ext_df.set_index('video_url')['product_brand']\n","\n","# Update only the empty rows — don't overwrite existing values\n","mask = needs_extraction\n","df.loc[mask, 'product_name']  = df.loc[mask, 'video_url'].map(pname_map)\n","df.loc[mask, 'product_brand'] = df.loc[mask, 'video_url'].map(pbrand_map)\n","\n","df.to_csv(CSV_PATH, index=False)\n","\n","# ── Summary ───────────────────────────────────────────────────────────\n","pname_final  = df['product_name'].apply(lambda x: not is_empty(x)).sum()\n","pbrand_final = df['product_brand'].apply(lambda x: not is_empty(x)).sum()\n","newly_found  = pname_final - (~needs_extraction).sum()\n","\n","print('\\n' + '='*50)\n","print('PRODUCT EXTRACTION COMPLETE')\n","print('='*50)\n","print(f'  product_name:  {pname_final}/731 ({pname_final/731*100:.1f}%)')\n","print(f'  product_brand: {pbrand_final}/731 ({pbrand_final/731*100:.1f}%)')\n","print(f'  Newly found:   {newly_found} additional products')\n","print(f'\\nSaved → {CSV_PATH}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"omgS1MjU56l2","executionInfo":{"status":"ok","timestamp":1777058157002,"user_tz":300,"elapsed":225770,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"6df8b824-9e55-40fa-b424-8e8d153a6bf5"},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Loaded: 731 rows\n","