n","CSV_FINAL    = f'{DATA_DIR}/TikTok_Acne_Final_Enriched.csv'\n","\n","print('✅ Config set')\n","print(f'   API key: {\"SET ✅\" if ANTHROPIC_API_KEY != \"sk-ant-YOUR_KEY_HERE\" else \"❌ MISSING\"}')"],"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Config set\n","   API key: SET ✅\n"]}]},{"cell_type":"code","metadata":{"id":"cell_load","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777057924258,"user_tz":300,"elapsed":565,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"f0343fde-1fce-4b39-e238-698a3d795368"},"source":["# ── STEP 4: Load CSV ────────────────────────────────────────────────\n","import pandas as pd, os\n","\n","if not os.path.exists(CSV_INPUT):\n","    from google.colab import files\n","    print('CSV not found — upload TikTok_Acne_Group2_Labeled.csv now...')\n","    uploaded = files.upload()\n","    import shutil\n","    shutil.copy(list(uploaded.keys())[0], CSV_INPUT)\n","\n","df = pd.read_csv(CSV_INPUT, dtype=str)  # read all as str to preserve IDs\n","\n","# Fix creator_username — currently stored as numeric ID, extract @handle from URL\n","df['creator_username'] = df['video_url'].str.extract(r'@([^/]+)')\n","\n","print(f'✅ Loaded: {len(df)} rows')\n","print(f'   creator_username sample: {df[\"creator_username\"].head(3).tolist()}')\n","print(f'   video_url sample: {df[\"video_url\"].head(1).tolist()}')\n","print()\n","print('EMPTY COLUMNS TO FILL:')\n","empty = [c for c in df.columns if (df[c].isna() | (df[c].astype(str).str.strip() == '')).all()]\n","print(f'  {empty}')"],"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Loaded: 731 rows\n","   creator_username sample: ['dr.mamina', 'kiki.13521', 'maddimccormack']\n","   video_url sample: ['https://www.tiktok.com/@dr.mamina/video/7255679807080385835']\n","\n","EMPTY COLUMNS TO FILL:\n","  ['creator_gender', 'creator_age_range', 'creator_race_visual', 'Posting date', 'No._people_video', 'video_shot_complexity', 'indoor_outdoor', 'video_format', 'Video_type', 'face_visibility', 'condition_extent', 'condition_duration', 'condition_recurrence', 'engagement_rate', 'comment_text', 'comment_stance', 'comment_sentiment']\n"]}]},{"cell_type":"code","metadata":{"id":"cell_scrape_meta","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776822496904,"user_tz":300,"elapsed":613,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"095c86cc-b625-4810-a830-1da5083d5ef1"},"source":["# ── STEP 5: Scrape metadata via yt-dlp (views, likes, shares, date) ─\n","# Free — no API key needed, no video download\n","import subprocess, json, time, os, pandas as pd\n","from tqdm import tqdm\n","\n","def scrape_meta(url, retries=2):\n","    \"\"\"Fetch TikTok video metadata without downloading.\"\"\"\n","    cmd = [\n","        'yt-dlp', '--no-download', '--dump-json', '--no-warnings',\n","        '--no-check-certificates',\n","        '--user-agent', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n","        '--add-header', 'Accept-Language:en-US,en;q=0.9',\n","        url\n","    ]\n","    for attempt in range(retries + 1):\n","        try:\n","            r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n","            if r.returncode == 0 and r.stdout.strip():\n","                d = json.loads(r.stdout.strip())\n","                return {\n","                    'video_url':          url,\n","                    'creator_followers':  d.get('channel_follower_count') or\n","                                          d.get('uploader_follower_count') or 0,\n","                    'views':              d.get('view_count') or 0,\n","                    'likes':              d.get('like_count') or 0,\n","                    'shares':             d.get('repost_count') or\n","                                          d.get('share_count') or 0,\n","                    'comments_scraped':   d.get('comment_count') or 0,\n","                    'Posting date':       d.get('upload_date') or '',\n","                    'scrape_status':      'success'\n","                }\n","        except Exception:\n","            if attempt < retries:\n","                time.sleep(2 ** attempt)\n","    return {'video_url': url, 'scrape_status': 'failed'}\n","\n","# Resume from checkpoint\n","ckpt_path = CSV_ENRICHED + '.ckpt'\n","if os.path.exists(ckpt_path):\n","    ckpt_df   = pd.read_csv(ckpt_path, dtype=str)\n","    done_urls = set(ckpt_df['video_url'].tolist())\n","    results   = ckpt_df.to_dict('records')\n","    print(f'Resuming — {len(done_urls)} already scraped')\n","else:\n","    done_urls, results = set(), []\n","\n","urls      = df['video_url'].tolist()\n","remaining = [u for u in urls if u not in done_urls]\n","print(f'Scraping metadata for {len(remaining)} URLs...')\n","print(f'Estimated time: ~40-60 mins\\n')\n","\n","for i, url in enumerate(tqdm(remaining)):\n","    results.append(scrape_meta(url))\n","    time.sleep(0.5)\n","    if (i + 1) % 50 == 0:\n","        pd.DataFrame(results).to_csv(ckpt_path, index=False)\n","        ok = sum(1 for r in results if r.get('scrape_status') == 'success')\n","        print(f'  [{len(results)}] {ok} succeeded')\n","\n","# Save full checkpoint\n","pd.DataFrame(results).to_csv(ckpt_path, index=False)\n","\n","meta_df = pd.DataFrame(results)\n","ok = (meta_df['scrape_status'] == 'success').sum()\n","print(f'\\n✅ Metadata scrape complete: {ok}/{len(urls)} succeeded')\n","print(f'   Failed: {len(urls) - ok} (TikTok blocks/deleted videos)')"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Resuming — 731 already scraped\n","Scraping metadata for 0 URLs...\n","Estimated time: ~40-60 mins\n","\n"]},{"output_type":"stream","name":"stderr","text":["0it [00:00, ?it/s]"]},{"output_type":"stream","name":"stdout","text":["\n","✅ Metadata scrape complete: 731/731 succeeded\n","   Failed: 0 (TikTok blocks/deleted videos)\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["import os\n","ckpt = DATA_DIR + '/comments.ckpt'\n","if os.path.exists(ckpt):\n","    os.remove(ckpt)\n","    print('✅ Cleared — now run Cell 6 with the new fetch_comments function')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yP-fncyV6XVs","executionInfo":{"status":"ok","timestamp":1776827984797,"user_tz":300,"elapsed":45,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"34143730-2d0b-45bc-8ab6-bc3ffe94c7e2"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Cleared — now run Cell 6 with the new fetch_comments function\n"]}]},{"cell_type":"code","metadata":{"id":"cell_merge_compute","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776828431732,"user_tz":300,"elapsed":164,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"54a05a5e-1bd1-4b26-bbdc-c3a6faf5ce27"},"source":["# ── STEP 7: Merge scraped data + compute engagement_rate ─────────────\n","import pandas as pd, numpy as np, os\n","\n","df = pd.read_csv(CSV_INPUT, dtype=str)\n","\n","# Guard: fail clearly if Cell 5 or Cell 6 haven't run yet\n","meta_ckpt = CSV_ENRICHED + '.ckpt'\n","comm_ckpt = DATA_DIR + '/comments.ckpt'\n","if not os.path.exists(meta_ckpt):\n","    raise FileNotFoundError(f'Metadata checkpoint not found: {meta_ckpt}\\nRun Cell 5 first.')\n","if not os.path.exists(comm_ckpt):\n","    raise FileNotFoundError(f'Comments checkpoint not found: {comm_ckpt}\\nRun Cell 6 first.')\n","\n","meta_df  = pd.read_csv(meta_ckpt, dtype=str)\n","comm_df  = pd.read_csv(comm_ckpt, dtype=str)\n","\n","# Fix creator_username — always extract from URL (authoritative)\n","df['creator_username'] = df['video_url'].str.extract(r'@([^/]+)')\n","\n","# Only keep successful scrapes for metadata\n","meta_ok = meta_df[meta_df['scrape_status'] == 'success'].copy()\n","\n","# Columns to bring in from metadata scrape\n","# Drop columns that exist in df (we'll overwrite via map, not merge)\n","meta_cols = ['video_url', 'creator_followers', 'views', 'likes',\n","             'shares', 'comments_scraped', 'Posting date']\n","meta_ok = meta_ok[[c for c in meta_cols if c in meta_ok.columns]]\n","\n","# Merge metadata — left join on video_url\n","# Drop existing empty columns from df before merge to avoid _x/_y suffixes\n","cols_to_overwrite = ['creator_followers', 'views', 'likes', 'shares', 'Posting date']\n","df = df.drop(columns=[c for c in cols_to_overwrite if c in df.columns], errors='ignore')\n","df = df.merge(meta_ok, on='video_url', how='left')\n","\n","# Merge comments — left join on video_url\n","df = df.drop(columns=['comment_text'], errors='ignore')\n","df = df.merge(comm_df[['video_url', 'comment_text']], on='video_url', how='left')\n","\n","# Compute engagement_rate = (likes / views) * 100, rounded to 2dp\n","# Convert to numeric first — coerce errors to NaN\n","df['views_num'] = pd.to_numeric(df['views'], errors='coerce')\n","df['likes_num'] = pd.to_numeric(df['likes'], errors='coerce')\n","df['engagement_rate'] = np.where(\n","    (df['views_num'] > 0) & df['views_num'].notna() & df['likes_num'].notna(),\n","    (df['likes_num'] / df['views_num'] * 100).round(2),\n","    np.nan\n",")\n","df = df.drop(columns=['views_num', 'likes_num'])\n","\n","# Update comments column from scraped count where available\n","# (original 'comments' col had count data already — keep it, just rename scraped)\n","if 'comments_scraped' in df.columns:\n","    # Only overwrite where original is empty\n","    mask = df['comments'].isna() | (df['comments'] == '')\n","    df.loc[mask, 'comments'] = df.loc[mask, 'comments_scraped']\n","    df = df.drop(columns=['comments_scraped'])\n","\n","# Save enriched CSV\n","df.to_csv(CSV_ENRICHED, index=False)\n","\n","print('✅ Merge + compute complete')\n","print()\n","print('FILL RATES AFTER MERGE:')\n","for col in ['creator_username', 'creator_followers', 'views', 'likes',\n","            'shares', 'Posting date', 'engagement_rate', 'comment_text']:\n","    if col in df.columns:\n","        filled = (df[col].notna() & (df[col].astype(str) != '') & (df[col].astype(str) != 'nan')).sum()\n","        pct = filled / len(df) * 100\n","        status = '✅' if pct > 80 else '⚠️ ' if pct > 30 else '❌'\n","        print(f'  {status} {col:<25} {filled}/{len(df)} ({pct:.1f}%)')\n","print()\n","print(f'engagement_rate sample: {df[\"engagement_rate\"].dropna().head(5).tolist()}')"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Merge + compute complete\n","\n","FILL RATES AFTER MERGE:\n","  ✅ creator_username          731/731 (100.0%)\n","  ✅ creator_followers         731/731 (100.0%)\n","  ✅ views                     731/731 (100.0%)\n","  ✅ likes                     731/731 (100.0%)\n","  ✅ shares                    731/731 (100.0%)\n","  ✅ Posting date              731/731 (100.0%)\n","  ✅ engagement_rate           731/731 (100.0%)\n","  ❌ comment_text              0/731 (0.0%)\n","\n","engagement_rate sample: [6.13, 4.53, 8.56, 6.77, 5.45]\n"]}]},{"cell_type":"code","metadata":{"id":"cell_final_assembly","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776828443996,"user_tz":300,"elapsed":185,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"c8e959d3-080c-45de-d760-ef70950d444f"},"source":["# ── STEP 9: Final assembly — reorder columns to match original schema ─\n","import pandas as pd\n","\n","df = pd.read_csv(CSV_ENRICHED, dtype=str)\n","\n","# Target column order — original 46 cols + new additions\n","col_order = [\n","    # Creator\n","    'creator_username', 'creator_gender', 'creator_age_range',\n","    'creator_race_visual', 'creator_type', 'creator_motivation',\n","    'creator_followers',\n","    # Video metadata\n","    'video_id', 'video_url', 'Posting date',\n","    # Visual features (manual)\n","    'No._people_video', 'video_shot_complexity', 'indoor_outdoor',\n","    'video_format', 'Video_type', 'face_visibility',\n","    # Content features\n","    'subject_of_experience', 'skin_condition_type',\n","    'condition_extent', 'condition_duration', 'condition_recurrence',\n","    'treatment_type', 'outcome_type', 'side_effects_mentioned',\n","    # Intent + promotion\n","    'video_intent', 'intent_clarity',\n","    'product_name', 'product_brand', 'sponsored_content',\n","    'affiliate_link_present', 'promotion_style',\n","    # Claims\n","    'before_after_claim', 'time_to_result_claim', 'unrealistic_claim_flag',\n","    # Engagement\n","    'views', 'likes', 'comments', 'shares', 'engagement_rate',\n","    # Comments\n","    'comment_text', 'comment_stance', 'comment_sentiment',\n","    # Classification\n","    'Missed_info', 'misinformation_label',\n","    'claim_type', 'claim_accuracy', 'evidence_present', 'label_confidence',\n","    # Raw text\n","    'caption', 'transcript'\n","]\n","\n","# Only include columns that actually exist\n","final_cols = [c for c in col_order if c in df.columns]\n","# Add any extra columns not in the order list\n","extra_cols = [c for c in df.columns if c not in final_cols]\n","if extra_cols:\n","    print(f'Extra cols appended: {extra_cols}')\n","df_final = df[final_cols + extra_cols]\n","df_final.to_csv(CSV_FINAL, index=False)\n","\n","print('✅ Final CSV assembled')\n","print(f'   Rows: {len(df_final)} | Columns: {len(df_final.columns)}')\n","print()\n","print('FINAL FILL RATES:')\n","for col in df_final.columns:\n","    filled = (df_final[col].notna() &\n","              (df_final[col].astype(str).str.strip() != '') &\n","              (df_final[col].astype(str).str.strip() != 'nan')).sum()\n","    pct = filled / len(df_final) * 100\n","    if pct == 0:\n","        status = '❌ (manual)'\n","    elif pct < 50:\n","        status = '⚠️ '\n","    else:\n","        status = '✅'\n","    print(f'  {status} {col:<35} {filled}/{len(df_final)} ({pct:.1f}%)')"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Final CSV assembled\n","   Rows: 731 | Columns: 50\n","\n","FINAL FILL RATES:\n","  ✅ creator_username                    731/731 (100.0%)\n","  ❌ (manual) creator_gender                      0/731 (0.0%)\n","  ❌ (manual) creator_age_range                   0/731 (0.0%)\n","  ❌ (manual) creator_race_visual                 0/731 (0.0%)\n","  ✅ creator_type                        731/731 (100.0%)\n","  ✅ creator_motivation                  731/731 (100.0%)\n","  ✅ creator_followers                   731/731 (100.0%)\n","  ✅ video_id                            731/731 (100.0%)\n","  ✅ video_url                           731/731 (100.0%)\n","  ✅ Posting date                        731/731 (100.0%)\n","  ❌ (manual) No._people_video                    0/731 (0.0%)\n","  ❌ (manual) video_shot_complexity               0/731 (0.0%)\n","  ❌ (manual) indoor_outdoor                      0/731 (0.0%)\n","  ❌ (manual) video_format                        0/731 (0.0%)\n","  ❌ (manual) Video_type                          0/731 (0.0%)\n","  ❌ (manual) face_visibility                     0/731 (0.0%)\n","  ✅ subject_of_experience               731/731 (100.0%)\n","  ✅ skin_condition_type                 731/731 (100.0%)\n","  ❌ (manual) condition_extent                    0/731 (0.0%)\n","  ❌ (manual) condition_duration                  0/731 (0.0%)\n","  ❌ (manual) condition_recurrence                0/731 (0.0%)\n","  ✅ treatment_type                      731/731 (100.0%)\n","  ✅ outcome_type                        731/731 (100.0%)\n","  ✅ side_effects_mentioned              731/731 (100.0%)\n","  ✅ video_intent                        731/731 (100.0%)\n","  ✅ intent_clarity                      731/731 (100.0%)\n","  ⚠️  product_name                        324/731 (44.3%)\n","  ⚠️  product_brand                       287/731 (39.3%)\n","  ✅ sponsored_content                   731/731 (100.0%)\n","  ✅ affiliate_link_present              731/731 (100.0%)\n","  ✅ promotion_style                     731/731 (100.0%)\n","  ✅ before_after_claim                  731/731 (100.0%)\n","  ✅ time_to_result_claim                731/731 (100.0%)\n","  ✅ unrealistic_claim_flag              731/731 (100.0%)\n","  ✅ views                               731/731 (100.0%)\n","  ✅ likes                               731/731 (100.0%)\n","  ✅ comments                            731/731 (100.0%)\n","  ✅ shares                              731/731 (100.0%)\n","  ✅ engagement_rate                     731/731 (100.0%)\n","  ❌ (manual) comment_text                        0/731 (0.0%)\n","  ❌ (manual) comment_stance                      0/731 (0.0%)\n","  ❌ (manual) comment_sentiment                   0/731 (0.0%)\n","  ✅ Missed_info                         716/731 (97.9%)\n","  ✅ misinformation_label                731/731 (100.0%)\n","  ✅ claim_type                          731/731 (100.0%)\n","  ✅ claim_accuracy                      731/731 (100.0%)\n","  ✅ evidence_present                    731/731 (100.0%)\n","  ✅ label_confidence                    731/731 (100.0%)\n","  ✅ caption                             731/731 (100.0%)\n","  ✅ transcript                          676/731 (92.5%)\n"]}]},{"cell_type":"code","metadata":{"id":"cell_validate","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776828453734,"user_tz":300,"elapsed":42,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"ebe95d81-475a-4a4a-82e5-1376d66df182"},"source":["# ── STEP 10: Validate data quality ──────────────────────────────────\n","import pandas as pd\n","\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","\n","print('='*55)\n","print('DATA QUALITY CHECKS')\n","print('='*55)\n","\n","# 1. Duplicate video_urls\n","dupes = df['video_url'].duplicated().sum()\n","print(f'Duplicate URLs: {dupes} {\"✅\" if dupes == 0 else \"❌\"}')\n","\n","# 2. engagement_rate range check\n","er = pd.to_numeric(df['engagement_rate'], errors='coerce').dropna()\n","if len(er) > 0:\n","    print(f'engagement_rate range: {er.min():.2f}% – {er.max():.2f}% (mean: {er.mean():.2f}%)')\n","    outliers = (er > 100).sum()\n","    print(f'  engagement_rate > 100%: {outliers} rows {\"⚠️\" if outliers > 0 else \"✅\"}')\n","else:\n","    print('engagement_rate: no data scraped yet ⚠️')\n","\n","# 3. creator_username — should be @handle not numeric\n","numeric_usernames = df['creator_username'].str.match(r'^\\d+$', na=False).sum()\n","print(f'Numeric creator_usernames: {numeric_usernames} {\"✅\" if numeric_usernames == 0 else \"❌\"}')\n","\n","# 4. Key classification columns — check for unexpected values\n","valid = {\n","    'misinformation_label': {'yes', 'no', 'partial'},\n","    'before_after_claim':   {'yes', 'no'},\n","    'label_confidence':     {'high', 'medium', 'low'},\n","    'claim_accuracy':       {'supported', 'partial', 'unsupported', 'false', 'na', 'anecdotal'},\n","    'comment_stance':       {'supportive', 'skeptical', 'neutral', 'mixed', 'na'},\n","    'comment_sentiment':    {'positive', 'negative', 'neutral', 'mixed', 'na'},\n","}\n","print()\n","print('VALUE VALIDATION:')\n","for col, allowed in valid.items():\n","    if col not in df.columns: continue\n","    unexpected = ~df[col].isin(allowed)\n","    n = unexpected.sum()\n","    bad_vals = df.loc[unexpected, col].unique()[:5] if n > 0 else []\n","    print(f'  {\"✅\" if n == 0 else \"⚠️ \"} {col:<25} {n} unexpected values {bad_vals if n > 0 else \"\"}')\n","\n","# 5. Key stats\n","print()\n","print('KEY RESEARCH STATS:')\n","print(f'  Total videos:          {len(df)}')\n","print(f'  Misinformation (yes):  {(df[\"misinformation_label\"]==\"yes\").sum()}')\n","print(f'  Misinformation (partial): {(df[\"misinformation_label\"]==\"partial\").sum()}')\n","print(f'  Before/after videos:   {(df[\"before_after_claim\"]==\"yes\").sum()}')\n","print(f'  Dermatologist videos:  {(df[\"creator_type\"]==\"dermatologist\").sum()}')\n","print(f'  Influencer videos:     {(df[\"creator_type\"]==\"influencer\").sum()}')\n","print(f'  Has engagement_rate:   {pd.to_numeric(df[\"engagement_rate\"], errors=\"coerce\").notna().sum()}')"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=======================================================\n","DATA QUALITY CHECKS\n","=======================================================\n","Duplicate URLs: 0 ✅\n","engagement_rate range: 0.11% – 53.25% (mean: 4.58%)\n","  engagement_rate > 100%: 0 rows ✅\n","Numeric creator_usernames: 0 ✅\n","\n","VALUE VALIDATION:\n","  ✅ misinformation_label      0 unexpected values \n","  ✅ before_after_claim        0 unexpected values \n","  ✅ label_confidence          0 unexpected values \n","  ✅ claim_accuracy            0 unexpected values \n","  ⚠️  comment_stance            731 unexpected values [nan]\n","  ⚠️  comment_sentiment         731 unexpected values [nan]\n","\n","KEY RESEARCH STATS:\n","  Total videos:          731\n","  Misinformation (yes):  25\n","  Misinformation (partial): 396\n","  Before/after videos:   120\n","  Dermatologist videos:  245\n","  Influencer videos:     254\n","  Has engagement_rate:   731\n"]}]},{"cell_type":"code","metadata":{"id":"cell_export","colab":{"base_uri":"https://localhost:8080/","height":69},"executionInfo":{"status":"ok","timestamp":1776828458317,"user_tz":300,"elapsed":36,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"a83405fb-9ea9-40a0-8f42-d07eac79352e"},"source":["# ── STEP 11: Export ──────────────────────────────────────────────────\n","from google.colab import files\n","import pandas as pd\n","\n","df = pd.read_csv(CSV_FINAL)\n","\n","print(f'✅ Final dataset: {len(df)} rows × {len(df.columns)} columns')\n","print(f'   Saved to Drive: {CSV_FINAL}')\n","print('Downloading...')\n","files.download(CSV_FINAL)"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Final dataset: 731 rows × 50 columns\n","   Saved to Drive: /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Final_Enriched.csv\n","Downloading...\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_a58df986-1b4a-4e65-a736-6380bf584492\", \"TikTok_Acne_Final_Enriched.csv\", 1222384)"]},"metadata":{}}]},{"cell_type":"code","source":["# ── Clear bad checkpoint before re-running ───────────────────────────\n","import os\n","if os.path.exists(CKPT_AUTH):\n","    os.remove(CKPT_AUTH)\n","    print('✅ Cleared — now run the scrape cell again')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yiONYE8OU3D7","executionInfo":{"status":"ok","timestamp":1776830086307,"user_tz":300,"elapsed":26,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"d02d3aa6-900f-461a-a6ff-40a00e2aa899"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Cleared — now run the scrape cell again\n"]}]},{"cell_type":"code","source":["# ── AUTH ENRICHMENT: creator_followers + comment_text ────────────────\n","# Fills 4 remaining columns:\n","#   creator_followers  → scraped from profile page (465 unique creators)\n","#   comment_text       → scraped from video page with cookies\n","#   comment_stance     → Claude Haiku on comment_text\n","#   comment_sentiment  → Claude Haiku on comment_text\n","#\n","# Requires: tiktok_cookies.txt in DATA_DIR\n","# Input:    CSV_FINAL (TikTok_Acne_Final_Enriched.csv)\n","# Output:   TikTok_Acne_Complete.csv\n","\n","import subprocess, json, time, os, tempfile, re, pandas as pd, numpy as np\n","import anthropic\n","from tqdm import tqdm\n","\n","# ── Paths ─────────────────────────────────────────────────────────────\n","COOKIES_PATH  = f'{DATA_DIR}/tiktok_cookies.txt'\n","CSV_COMPLETE  = f'{DATA_DIR}/TikTok_Acne_Complete.csv'\n","CKPT_PROFILE  = f'{DATA_DIR}/ckpt_profiles.csv'\n","CKPT_COMMENTS = f'{DATA_DIR}/ckpt_comments_auth.csv'\n","CKPT_CLASSIFY = f'{DATA_DIR}/ckpt_classify.csv'\n","\n","# ── Verify setup ──────────────────────────────────────────────────────\n","if not os.path.exists(COOKIES_PATH):\n","    raise FileNotFoundError(\n","        f'Cookies not found: {COOKIES_PATH}\\n'\n","        'Upload tiktok_cookies.txt to Drive first.'\n","    )\n","if ANTHROPIC_API_KEY == 'sk-ant-YOUR_KEY_HERE':\n","    raise ValueError('Paste your Anthropic API key in Cell 3 first.')\n","\n","print('✅ Cookies found')\n","print(f'✅ API key set')\n","\n","# ── Load CSV ──────────────────────────────────────────────────────────\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","df['creator_username'] = df['video_url'].str.extract(r'@([^/]+)')\n","print(f'✅ Loaded: {len(df)} rows, {df['creator_username'].nunique()} unique creators')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# PHASE 1: Scrape creator_followers (per unique creator — 465 requests)\n","# ═══════════════════════════════════════════════════════════════════════\n","print('\\n── PHASE 1: creator_followers ──────────────────────────────────')\n","\n","def scrape_followers(username, retries=2):\n","    \"\"\"Scrape follower count from TikTok profile page.\"\"\"\n","    profile_url = f'https://www.tiktok.com/@{username}'\n","    cmd = [\n","        'yt-dlp', '--no-download', '--dump-json', '--no-warnings',\n","        '--no-check-certificates',\n","        '--cookies', COOKIES_PATH,\n","        '--user-agent', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n","        '--add-header', 'Accept-Language:en-US,en;q=0.9',\n","        '--playlist-items', '1',\n","        profile_url\n","    ]\n","    for attempt in range(retries + 1):\n","        try:\n","            r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n","            if r.returncode == 0 and r.stdout.strip():\n","                # Profile returns multiple JSON lines — check each for follower data\n","                for line in r.stdout.strip().split('\\n'):\n","                    try:\n","                        d = json.loads(line)\n","                        followers = (\n","                            d.get('channel_follower_count') or\n","                            d.get('uploader_follower_count') or\n","                            d.get('follower_count') or\n","                            d.get('uploader', {}).get('followerCount') if isinstance(d.get('uploader'), dict) else None\n","                        )\n","                        if followers and int(followers) > 0:\n","                            return {'username': username, 'creator_followers': int(followers), 'status': 'ok'}\n","                    except Exception:\n","                        continue\n","        except Exception:\n","            if attempt < retries:\n","                time.sleep(2 ** attempt)\n","    return {'username': username, 'creator_followers': 0, 'status': 'failed'}\n","\n","# Resume from checkpoint\n","if os.path.exists(CKPT_PROFILE):\n","    prof_ckpt   = pd.read_csv(CKPT_PROFILE, dtype=str)\n","    done_users  = set(prof_ckpt['username'].tolist())\n","    prof_results = prof_ckpt.to_dict('records')\n","    print(f'Resuming profiles — {len(done_users)} already done')\n","else:\n","    done_users, prof_results = set(), []\n","\n","all_users = df['creator_username'].dropna().unique().tolist()\n","rem_users = [u for u in all_users if u not in done_users]\n","print(f'Scraping {len(rem_users)} remaining profiles...')\n","\n","for i, username in enumerate(tqdm(rem_users)):\n","    prof_results.append(scrape_followers(username))\n","    time.sleep(0.8)\n","    if (i + 1) % 50 == 0:\n","        pd.DataFrame(prof_results).to_csv(CKPT_PROFILE, index=False)\n","        ok = sum(1 for r in prof_results if int(r.get('creator_followers', 0) or 0) > 0)\n","        print(f'  [{len(prof_results)}] followers found: {ok}')\n","\n","pd.DataFrame(prof_results).to_csv(CKPT_PROFILE, index=False)\n","prof_df = pd.DataFrame(prof_results)\n","\n","# Map followers to all videos by username\n","follower_map = prof_df.set_index('username')['creator_followers']\n","df['creator_followers'] = df['creator_username'].map(follower_map).fillna(0).astype(str)\n","\n","ok = (pd.to_numeric(df['creator_followers'], errors='coerce') > 0).sum()\n","print(f'\\n✅ Phase 1 complete: {ok}/731 videos have follower count')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# PHASE 2: Scrape comment_text (per video — 731 requests)\n","# ═══════════════════════════════════════════════════════════════════════\n","print('\\n── PHASE 2: comment_text ───────────────────────────────────────')\n","\n","def scrape_comments(url, max_comments=5, retries=2):\n","    \"\"\"Fetch top comments via temp info.json file with cookies.\"\"\"\n","    with tempfile.TemporaryDirectory() as tmpdir:\n","        cmd = [\n","            'yt-dlp',\n","            '--no-download',\n","            '--write-comments',\n","            '--write-info-json',\n","            '--no-warnings',\n","            '--no-check-certificates',\n","            '--cookies', COOKIES_PATH,\n","            '--extractor-args', f'tiktok:max_comments={max_comments}',\n","            '--user-agent', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n","            '--add-header', 'Accept-Language:en-US,en;q=0.9',\n","            '-o', os.path.join(tmpdir, '%(id)s'),\n","            url\n","        ]\n","        for attempt in range(retries + 1):\n","            try:\n","                r = subprocess.run(cmd, capture_output=True, text=True, timeout=45)\n","                info_files = [f for f in os.listdir(tmpdir) if f.endswith('.info.json')]\n","                if not info_files:\n","                    if attempt < retries:\n","                        time.sleep(2 ** attempt)\n","                    continue\n","                with open(os.path.join(tmpdir, info_files[0]), encoding='utf-8') as f:\n","                    d = json.load(f)\n","                raw = d.get('comments') or []\n","                if raw:\n","                    top = sorted(raw, key=lambda c: c.get('like_count', 0), reverse=True)[:max_comments]\n","                    texts = [c.get('text', '').strip() for c in top if c.get('text', '').strip()]\n","                    return {'video_url': url, 'comment_text': ' | '.join(texts), 'status': 'ok'}\n","                return {'video_url': url, 'comment_text': '', 'status': 'no_comments'}\n","            except Exception:\n","                if attempt < retries:\n","                    time.sleep(2 ** attempt)\n","    return {'video_url': url, 'comment_text': '', 'status': 'failed'}\n","\n","# Resume from checkpoint\n","if os.path.exists(CKPT_COMMENTS):\n","    comm_ckpt   = pd.read_csv(CKPT_COMMENTS, dtype=str)\n","    done_comm   = set(comm_ckpt['video_url'].tolist())\n","    comm_results = comm_ckpt.to_dict('records')\n","    print(f'Resuming comments — {len(done_comm)} already done')\n","else:\n","    done_comm, comm_results = set(), []\n","\n","rem_urls = [u for u in df['video_url'].tolist() if u not in done_comm]\n","print(f'Fetching comments for {len(rem_urls)} remaining videos...')\n","\n","for i, url in enumerate(tqdm(rem_urls)):\n","    comm_results.append(scrape_comments(url))\n","    time.sleep(1.0)\n","    if (i + 1) % 50 == 0:\n","        pd.DataFrame(comm_results).to_csv(CKPT_COMMENTS, index=False)\n","        ok = sum(1 for r in comm_results if r.get('comment_text', ''))\n","        print(f'  [{len(comm_results)}] had comments: {ok}')\n","\n","pd.DataFrame(comm_results).to_csv(CKPT_COMMENTS, index=False)\n","comm_df = pd.DataFrame(comm_results)\n","\n","# Merge comment_text back\n","comment_map = comm_df.set_index('video_url')['comment_text']\n","df = df.drop(columns=['comment_text'], errors='ignore')\n","df['comment_text'] = df['video_url'].map(comment_map).fillna('')\n","\n","ok = (df['comment_text'].str.strip() != '').sum()\n","print(f'\\n✅ Phase 2 complete: {ok}/731 videos have comment_text')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# PHASE 3: Claude Haiku — comment_stance + comment_sentiment\n","# ═══════════════════════════════════════════════════════════════════════\n","print('\\n── PHASE 3: comment_stance + comment_sentiment ─────────────────')\n","\n","client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","\n","SYSTEM = \"\"\"You are classifying TikTok comments for a dermatology misinformation study.\n","Respond ONLY with a valid JSON object — no markdown, no explanation.\n","\n","comment_stance:    Are the comments supportive of the video's claims, or skeptical?\n","  Values: supportive | skeptical | neutral | mixed\n","\n","comment_sentiment: What is the overall emotional tone of the comments?\n","  Values: positive | negative | neutral | mixed\"\"\"\n","\n","VALID_STANCE     = {'supportive', 'skeptical', 'neutral', 'mixed'}\n","VALID_SENTIMENT  = {'positive', 'negative', 'neutral', 'mixed'}\n","DEFAULT_CLS      = {'comment_stance': 'na', 'comment_sentiment': 'na'}\n","\n","def classify_comments(comment_text, retries=2):\n","    if not comment_text or str(comment_text).strip() in ('', 'nan'):\n","        return DEFAULT_CLS.copy()\n","    prompt = (\n","        f'COMMENTS (top 5, separated by |):\\n{str(comment_text)[:800]}\\n\\n'\n","        'Return JSON with comment_stance and comment_sentiment.'\n","    )\n","    for attempt in range(retries + 1):\n","        try:\n","            resp = client.messages.create(\n","                model='claude-haiku-4-5-20251001',\n","                max_tokens=60,\n","                system=SYSTEM,\n","                messages=[{'role': 'user', 'content': prompt}]\n","            )\n","            text = resp.content[0].text.strip()\n","            if text.startswith('```'):\n","                text = text.split('```')[1]\n","                if text.startswith('json'): text = text[4:]\n","            result = json.loads(text)\n","            return {\n","                'comment_stance':    result.get('comment_stance', 'neutral')\n","                                     if result.get('comment_stance') in VALID_STANCE\n","                                     else 'neutral',\n","                'comment_sentiment': result.get('comment_sentiment', 'neutral')\n","                                     if result.get('comment_sentiment') in VALID_SENTIMENT\n","                                     else 'neutral'\n","            }\n","        except anthropic.RateLimitError:\n","            print('Rate limit — waiting 60s...')\n","            time.sleep(60)\n","        except json.JSONDecodeError:\n","            if attempt < retries: time.sleep(1)\n","        except Exception:\n","            if attempt < retries: time.sleep(2)\n","    return DEFAULT_CLS.copy()\n","\n","# Only classify rows that have comment_text\n","has_comments = df['comment_text'].notna() & (df['comment_text'].str.strip() != '') & \\\n","               (df['comment_text'].str.strip() != 'nan')\n","to_classify  = df[has_comments]\n","print(f'Videos with comments to classify: {len(to_classify)}')\n","print(f'Estimated cost: ~${len(to_classify) * 0.0001:.3f} (Haiku)\\n')\n","\n","# Resume from checkpoint\n","if os.path.exists(CKPT_CLASSIFY):\n","    cls_ckpt    = pd.read_csv(CKPT_CLASSIFY, dtype=str)\n","    done_cls    = set(cls_ckpt['video_url'].tolist())\n","    cls_results = cls_ckpt.to_dict('records')\n","    print(f'Resuming classification — {len(done_cls)} already done')\n","else:\n","    done_cls, cls_results = set(), []\n","\n","rem_cls = to_classify[~to_classify['video_url'].isin(done_cls)]\n","\n","for _, row in tqdm(rem_cls.iterrows(), total=len(rem_cls)):\n","    ct  = row['comment_text'] if pd.notna(row['comment_text']) else ''\n","    cls = classify_comments(str(ct))\n","    cls['video_url'] = row['video_url']\n","    cls_results.append(cls)\n","    time.sleep(0.1)\n","    if len(cls_results) % 100 == 0:\n","        pd.DataFrame(cls_results).to_csv(CKPT_CLASSIFY, index=False)\n","        print(f'  Checkpoint: {len(cls_results)} classified')\n","\n","pd.DataFrame(cls_results).to_csv(CKPT_CLASSIFY, index=False)\n","\n","# Merge classification back\n","if cls_results:\n","    cls_df = pd.DataFrame(cls_results)\n","elif os.path.exists(CKPT_CLASSIFY) and os.path.getsize(CKPT_CLASSIFY) > 0:\n","    cls_df = pd.read_csv(CKPT_CLASSIFY, dtype=str)\n","else:\n","    # If no results and checkpoint is empty or doesn't exist, create an empty DataFrame\n","    cls_df = pd.DataFrame(columns=['video_url', 'comment_stance', 'comment_sentiment'])\n","\n","df = df.drop(columns=['comment_stance', 'comment_sentiment'], errors='ignore')\n","df = df.merge(cls_df[['video_url', 'comment_stance', 'comment_sentiment']],\n","              on='video_url', how='left')\n","df['comment_stance']    = df['comment_stance'].fillna('na')\n","df['comment_sentiment'] = df['comment_sentiment'].fillna('na')\n","\n","cls_ok = (df['comment_stance'] != 'na').sum()\n","print(f'\\n✅ Phase 3 complete: {cls_ok} classified')\n","\n","# ═══════════════════════════════════════════════════════════════════════\n","# FINAL: Save + summary\n","# ═══════════════════════════════════════════════════════════════════════\n","df.to_csv(CSV_COMPLETE, index=False)\n","\n","print('\\n' + '='*55)\n","print('ENRICHMENT COMPLETE')\n","print('='*55)\n","print(f'Output: {CSV_COMPLETE}')\n","print()\n","print('FILL RATES:')\n","for col in ['creator_followers', 'comment_text', 'comment_stance', 'comment_sentiment']:\n","    if col in df.columns:\n","        filled = (df[col].notna() & (df[col].astype(str).str.strip() != '') &\n","                  (df[col].astype(str) != 'nan') & (df[col].astype(str) != '0')).sum()\n","        pct = filled / len(df) * 100\n","        status = '✅' if pct > 80 else '⚠️ ' if pct > 0 else '❌'\n","        print(f'  {status} {col:<25} {filled}/{len(df)} ({pct:.1f}%)')\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Ra4cIFo-Vlnq","outputId":"8ef0cc5f-35bc-4d45-86cc-baa7f4385db2"},"execution_count":null,"outputs":[{"metadata":{"tags":null},"name":"stdout","output_type":"stream","text":["✅ Cookies found\n","✅ API key set\n","✅ Loaded: 731 rows, 465 unique creators\n","\n","── PHASE 1: creator_followers ──────────────────────────────────\n","Resuming profiles — 50 already done\n","Scraping 415 remaining profiles...\n"]},{"metadata":{"tags":null},"name":"stderr","output_type":"stream","text":[" 12%|█▏        | 50/415 [05:55<42:40,  7.01s/it]"]},{"metadata":{"tags":null},"name":"stdout","output_type":"stream","text":["  [100] followers found: 0\n"]},{"output_type":"stream","name":"stderr","text":[" 24%|██▍       | 100/415 [11:33<35:03,  6.68s/it]"]},{"output_type":"stream","name":"stdout","text":["  [150] followers found: 0\n"]},{"output_type":"stream","name":"stderr","text":[" 34%|███▎      | 140/415 [16:06<30:45,  6.71s/it]"]}]},{"cell_type":"code","source":["from google.colab import files\n","import pandas as pd\n","\n","df_out = pd.read_csv(CSV_COMPLETE)\n","print(f'✅ {len(df_out)} rows × {len(df_out.columns)} columns')\n","files.download(CSV_COMPLETE)"],"metadata":{"id":"iK40mZRIVtvZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ── FINALIZE: save current dataset as complete for now ───────────────\n","import pandas as pd\n","\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","\n","# Mark the 4 pending columns clearly as empty\n","for col in ['creator_followers', 'comment_text', 'comment_stance', 'comment_sentiment']:\n","    if col not in df.columns:\n","        df[col] = ''\n","    else:\n","        df[col] = ''\n","\n","CSV_COMPLETE = f'{DATA_DIR}/TikTok_Acne_Complete.csv'\n","df.to_csv(CSV_COMPLETE, index=False)\n","\n","print(f'✅ Saved: {len(df)} rows × {len(df.columns)} columns')\n","print(f'   → {CSV_COMPLETE}')\n","print()\n","print('FILL SUMMARY:')\n","for col in df.columns:\n","    filled = (df[col].notna() & (df[col].astype(str).str.strip() != '') & (df[col].astype(str) != 'nan')).sum()\n","    pct = filled / len(df) * 100\n","    status = '✅' if pct > 80 else '⚠️ ' if pct > 0 else '❌'\n","    print(f'  {status} {col:<35} {pct:.0f}%')"],"metadata":{"id":"slSQJLMXXyGd","executionInfo":{"status":"ok","timestamp":1776830854672,"user_tz":300,"elapsed":394,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"a017b02c-59c2-43d6-9614-98f3eb5ce84d","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Saved: 731 rows × 50 columns\n","   → /content/drive/MyDrive/TikTok_Acne_Research/data/TikTok_Acne_Complete.csv\n","\n","FILL SUMMARY:\n","  ✅ creator_username                    100%\n","  ❌ creator_gender                      0%\n","  ❌ creator_age_range                   0%\n","  ❌ creator_race_visual                 0%\n","  ✅ creator_type                        100%\n","  ✅ creator_motivation                  100%\n","  ❌ creator_followers                   0%\n","  ✅ video_id                            100%\n","  ✅ video_url                           100%\n","  ✅ Posting date                        100%\n","  ❌ No._people_video                    0%\n","  ❌ video_shot_complexity               0%\n","  ❌ indoor_outdoor                      0%\n","  ❌ video_format                        0%\n","  ❌ Video_type                          0%\n","  ❌ face_visibility                     0%\n","  ✅ subject_of_experience               100%\n","  ✅ skin_condition_type                 100%\n","  ❌ condition_extent                    0%\n","  ❌ condition_duration                  0%\n","  ❌ condition_recurrence                0%\n","  ✅ treatment_type                      100%\n","  ✅ outcome_type                        100%\n","  ✅ side_effects_mentioned              100%\n","  ✅ video_intent                        100%\n","  ✅ intent_clarity                      100%\n","  ⚠️  product_name                        44%\n","  ⚠️  product_brand                       39%\n","  ✅ sponsored_content                   100%\n","  ✅ affiliate_link_present              100%\n","  ✅ promotion_style                     100%\n","  ✅ before_after_claim                  100%\n","  ✅ time_to_result_claim                100%\n","  ✅ unrealistic_claim_flag              100%\n","  ✅ views                               100%\n","  ✅ likes                               100%\n","  ✅ comments                            100%\n","  ✅ shares                              100%\n","  ✅ engagement_rate                     100%\n","  ❌ comment_text                        0%\n","  ❌ comment_stance                      0%\n","  ❌ comment_sentiment                   0%\n","  ✅ Missed_info                         98%\n","  ✅ misinformation_label                100%\n","  ✅ claim_type                          100%\n","  ✅ claim_accuracy                      100%\n","  ✅ evidence_present                    100%\n","  ✅ label_confidence                    100%\n","  ✅ caption                             100%\n","  ✅ transcript                          92%\n"]}]},{"cell_type":"code","source":["from google.colab import files\n","files.download(CSV_COMPLETE)"],"metadata":{"id":"xY9AiqFxX2iG","executionInfo":{"status":"ok","timestamp":1776830871634,"user_tz":300,"elapsed":33,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"558bd815-76e9-4277-b5dc-b9163a35668f","colab":{"base_uri":"https://localhost:8080/","height":17}},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_af3809c0-a060-474a-954f-2f8a23367f00\", \"TikTok_Acne_Complete.csv\", 1221653)"]},"metadata":{}}]},{"cell_type":"code","source":["import os\n","ckpt = DATA_DIR + '/ckpt_apify.csv'\n","if os.path.exists(ckpt):\n","    os.remove(ckpt)\n","    print('✅ Cleared')"],"metadata":{"id":"YC0x5vgl5ViF"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ── PARALLEL APIFY: creator_followers + comment_text simultaneously ───\n","# Thread A: clockworks~free-tiktok-scraper  → creator_followers (free)\n","# Thread B: clockworks~tiktok-scraper        → comment_text (paid ~$1.50)\n","# Then: Claude Haiku → comment_stance + comment_sentiment\n","#\n","# Input:  CSV_FINAL (TikTok_Acne_Final_Enriched.csv)\n","# Output: TikTok_Acne_Complete.csv\n","\n","import requests, json, time, os, threading, pandas as pd, anthropic\n","from tqdm import tqdm\n","\n","# ── Config ────────────────────────────────────────────────────────────\n","APIFY_TOKEN      = os.environ["APIFY_TOKEN"]   # ← paste your token\n","ACTOR_FOLLOWERS  = 'clockworks~free-tiktok-scraper'\n","ACTOR_COMMENTS   = 'apidojo~tiktok-comments-scraper'\n","BATCH_SIZE       = 50\n","COMMENTS_COUNT   = 5\n","\n","CSV_COMPLETE     = f'{DATA_DIR}/TikTok_Acne_Complete.csv'\n","CKPT_FOLLOWERS   = f'{DATA_DIR}/ckpt_followers.csv'\n","CKPT_COMMENTS_AP = f'{DATA_DIR}/ckpt_comments_ap.csv'\n","CKPT_CLASSIFY    = f'{DATA_DIR}/ckpt_classify.csv'\n","\n","# ── Verify setup ──────────────────────────────────────────────────────\n","if APIFY_TOKEN == 'YOUR_APIFY_TOKEN_HERE':\n","    raise ValueError('Paste your Apify token above.')\n","if ANTHROPIC_API_KEY == 'sk-ant-YOUR_KEY_HERE':\n","    raise ValueError('Paste your Anthropic API key in Cell 3.')\n","\n","test_r = requests.get(f'https://api.apify.com/v2/users/me?token={APIFY_TOKEN}')\n","if test_r.status_code != 200:\n","    raise ValueError(f'Invalid Apify token — {test_r.json()}')\n","print(f'✅ Apify token: {test_r.json()[\"data\"][\"username\"]}')\n","\n","# Check Apify memory usage — warn if close to limit\n","runs_r = requests.get(\n","    f'https://api.apify.com/v2/actor-runs?token={APIFY_TOKEN}&status=RUNNING&limit=10'\n",")\n","if runs_r.status_code == 200:\n","    running = runs_r.json().get('data', {}).get('items', [])\n","    used_mb = sum(r.get('options', {}).get('memoryMbytes', 0) for r in running)\n","    print(f'Apify memory in use: {used_mb}MB / 8192MB')\n","    if used_mb > 4096:\n","        print('⚠️  WARNING: >4GB in use. Delete old runs at console.apify.com/actors/runs first.')\n","\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","print(f'✅ Loaded: {len(df)} rows')\n","\n","# ── Thread-safe logging + exception tracking ──────────────────────────\n","log_lock   = threading.Lock()\n","thread_exc = {}\n","\n","def log(name, msg):\n","    with log_lock:\n","        print(f'[{name:<9}] {msg}', flush=True)\n","\n","# ── Helpers ───────────────────────────────────────────────────────────\n","def parse_followers(v):\n","    \"\"\"Safely convert follower count — handles '1.2M', '10K', int, None.\"\"\"\n","    try:\n","        s = str(v).strip().upper().replace(',', '')\n","        if s.endswith('M'):\n","            return int(float(s[:-1]) * 1_000_000)\n","        if s.endswith('K'):\n","            return int(float(s[:-1]) * 1_000)\n","        return int(float(s))\n","    except Exception:\n","        return 0\n","\n","def valid_url(url):\n","    \"\"\"Check URL looks like a real TikTok video URL.\"\"\"\n","    return url and '@' in url and '/video/' in url\n","\n","def run_apify_batch(actor_id, payload, name, batch_num, total):\n","    \"\"\"Start Apify run, poll until done, return items list.\"\"\"\n","    log(name, f'Batch {batch_num}/{total} — {len(payload[\"postURLs\"])} videos')\n","\n","    # Start run\n","    try:\n","        run_resp = requests.post(\n","            f'https://api.apify.com/v2/acts/{actor_id}/runs'\n","            f'?token={APIFY_TOKEN}&memory=2048&timeout=600',\n","            json=payload,\n","            timeout=30\n","        )\n","    except Exception as e:\n","        log(name, f'❌ Request failed: {e}')\n","        return []\n","\n","    if run_resp.status_code not in (200, 201):\n","        log(name, f'❌ Start failed {run_resp.status_code}: {run_resp.text[:200]}')\n","        return []\n","\n","    run_data   = run_resp.json().get('data', {})\n","    run_id     = run_data.get('id')\n","    dataset_id = run_data.get('defaultDatasetId')\n","    if not run_id or not dataset_id:\n","        log(name, f'❌ Missing run_id or dataset_id in response')\n","        return []\n","    log(name, f'Run ID: {run_id}')\n","\n","    # Poll status\n","    for _ in range(80):   # max 40 mins (80 × 30s)\n","        time.sleep(30)\n","        try:\n","            status_resp = requests.get(\n","                f'https://api.apify.com/v2/actor-runs/{run_id}?token={APIFY_TOKEN}',\n","                timeout=15\n","            )\n","            status = status_resp.json()['data']['status']\n","        except Exception:\n","            log(name, 'Warning: status parse failed, retrying...')\n","            continue\n","        log(name, f'Status: {status}')\n","        if status == 'SUCCEEDED':\n","            break\n","        if status in ('FAILED', 'ABORTED', 'TIMED-OUT'):\n","            log(name, f'❌ Run {status}')\n","            return []\n","    else:\n","        log(name, '❌ Polling timed out after 40 mins')\n","        return []\n","\n","    # Fetch results\n","    try:\n","        items_resp = requests.get(\n","            f'https://api.apify.com/v2/datasets/{dataset_id}/items'\n","            f'?format=json&token={APIFY_TOKEN}',\n","            timeout=60\n","        )\n","        items = items_resp.json()\n","    except Exception as e:\n","        log(name, f'❌ Failed to fetch/parse results: {e}')\n","        return []\n","\n","    log(name, f'✅ Got {len(items)} results')\n","    return items\n","\n","# ─────────────────────────────────────────────────────────────────────\n","# THREAD A: creator_followers\n","# ─────────────────────────────────────────────────────────────────────\n","def scrape_followers_thread():\n","    name = 'FOLLOWERS'\n","    try:\n","        log(name, 'Starting...')\n","\n","        # Resume from checkpoint\n","        if os.path.exists(CKPT_FOLLOWERS):\n","            ckpt      = pd.read_csv(CKPT_FOLLOWERS, dtype=str)\n","            done_urls = set(ckpt['video_url'].tolist())\n","            results   = ckpt.to_dict('records')\n","            log(name, f'Resuming — {len(done_urls)} already done')\n","        else:\n","            done_urls, results = set(), []\n","\n","        all_urls = df['video_url'].tolist()\n","        rem_urls = [u for u in all_urls if u not in done_urls]\n","        batches  = [rem_urls[i:i+BATCH_SIZE] for i in range(0, len(rem_urls), BATCH_SIZE)]\n","        log(name, f'{len(rem_urls)} remaining across {len(batches)} batches')\n","\n","        for batch_num, batch_urls in enumerate(batches, 1):\n","            items = run_apify_batch(\n","                ACTOR_FOLLOWERS,\n","                {\n","                    'postURLs':                batch_urls,\n","                    'resultsLimit':            len(batch_urls),\n","                    'shouldDownloadVideos':    False,\n","                    'shouldDownloadCovers':    False,\n","                    'shouldDownloadSubtitles': False,\n","                },\n","                name, batch_num, len(batches)\n","            )\n","\n","            for item in items:\n","                if not item or item.get('error'):\n","                    continue\n","                video_url = (\n","                    item.get('webVideoUrl') or\n","                    item.get('videoUrl') or\n","                    f\"https://www.tiktok.com/@{item.get('authorMeta', {}).get('name', '')}/video/{item.get('id', '')}\"\n","                )\n","                if not valid_url(video_url):\n","                    continue\n","                author    = item.get('authorMeta') or {}\n","                followers = author.get('fans') or author.get('followers') or 0\n","                results.append({\n","                    'video_url':         video_url,\n","                    'creator_followers': parse_followers(followers),\n","                })\n","\n","            pd.DataFrame(results).to_csv(CKPT_FOLLOWERS, index=False)\n","            ok = sum(1 for r in results if int(r.get('creator_followers', 0) or 0) > 0)\n","            log(name, f'Total: {len(results)} | followers > 0: {ok}')\n","\n","            if batch_num < len(batches):\n","                log(name, 'Waiting 30s before next batch...')\n","                time.sleep(30)\n","\n","        log(name, '✅ Done')\n","\n","    except Exception as e:\n","        log(name, f'❌ Crashed: {e}')\n","        thread_exc['followers'] = e\n","\n","# ─────────────────────────────────────────────────────────────────────\n","# THREAD B: comment_text\n","# ─────────────────────────────────────────────────────────────────────\n","def scrape_comments_thread():\n","    name = 'COMMENTS'\n","    try:\n","        log(name, 'Starting...')\n","\n","        # Resume from checkpoint\n","        if os.path.exists(CKPT_COMMENTS_AP):\n","            ckpt      = pd.read_csv(CKPT_COMMENTS_AP, dtype=str)\n","            done_urls = set(ckpt['video_url'].tolist())\n","            results   = ckpt.to_dict('records')\n","            log(name, f'Resuming — {len(done_urls)} already done')\n","        else:\n","            done_urls, results = set(), []\n","\n","        all_urls = df['video_url'].tolist()\n","        rem_urls = [u for u in all_urls if u not in done_urls]\n","        batches  = [rem_urls[i:i+BATCH_SIZE] for i in range(0, len(rem_urls), BATCH_SIZE)]\n","        log(name, f'{len(rem_urls)} remaining across {len(batches)} batches')\n","\n","        for batch_num, batch_urls in enumerate(batches, 1):\n","            items = run_apify_batch(\n","                ACTOR_COMMENTS,\n","                {\n","                    'postURLs':                batch_urls,\n","                    'commentsCount':           COMMENTS_COUNT,\n","                    'resultsLimit':            len(batch_urls),\n","                    'shouldDownloadVideos':    False,\n","                    'shouldDownloadCovers':    False,\n","                    'shouldDownloadSubtitles': False,\n","                },\n","                name, batch_num, len(batches)\n","            )\n","\n","            # apidojo returns one row per COMMENT — group by video URL\n","            from collections import defaultdict\n","            comments_by_video = defaultdict(list)\n","            for item in items:\n","                if not item or item.get('error'):\n","                    continue\n","                # video URL is on the comment item itself\n","                video_url = (\n","                    item.get('videoUrl') or\n","                    item.get('webVideoUrl') or\n","                    item.get('postUrl') or ''\n","                )\n","                if not valid_url(video_url):\n","                    continue\n","                text = (item.get('text') or item.get('commentText') or '').strip()\n","                if text:\n","                    comments_by_video[video_url].append({\n","                        'text':      text,\n","                        'diggCount': item.get('diggCount') or item.get('likeCount') or 0\n","                    })\n","\n","            # Top 5 comments per video by diggCount\n","            for video_url, comment_list in comments_by_video.items():\n","                top   = sorted(comment_list, key=lambda c: c['diggCount'], reverse=True)[:COMMENTS_COUNT]\n","                texts = [c['text'] for c in top if c['text']]\n","                results.append({\n","                    'video_url':    video_url,\n","                    'comment_text': ' | '.join(texts) if texts else '',\n","                })\n","\n","            pd.DataFrame(results).to_csv(CKPT_COMMENTS_AP, index=False)\n","            ok = sum(1 for r in results if r.get('comment_text', ''))\n","            log(name, f'Total: {len(results)} | with comments: {ok}')\n","\n","            if batch_num < len(batches):\n","                log(name, 'Waiting 30s before next batch...')\n","                time.sleep(30)\n","\n","        log(name, '✅ Done')\n","\n","    except Exception as e:\n","        log(name, f'❌ Crashed: {e}')\n","        thread_exc['comments'] = e\n","\n","# ─────────────────────────────────────────────────────────────────────\n","# RUN BOTH THREADS IN PARALLEL\n","# ─────────────────────────────────────────────────────────────────────\n","print('\\n── Starting parallel scrape ─────────────────────────────────────')\n","print('FOLLOWERS → clockworks~free-tiktok-scraper (free)')\n","print('COMMENTS  → clockworks~tiktok-scraper (paid ~$1.50)')\n","print()\n","\n","t_followers = threading.Thread(target=scrape_followers_thread, daemon=True)\n","t_comments  = threading.Thread(target=scrape_comments_thread,  daemon=True)\n","\n","t_followers.start()\n","time.sleep(15)       # stagger 15s to avoid simultaneous memory spike\n","t_comments.start()\n","\n","t_followers.join()\n","t_comments.join()\n","\n","print('\\n── Both threads complete ────────────────────────────────────────')\n","\n","# Report any thread errors\n","if thread_exc:\n","    for tname, exc in thread_exc.items():\n","        print(f'⚠️  {tname} thread error: {exc}')\n","    print('Partial data available in checkpoints — continuing with merge.')\n","\n","# ─────────────────────────────────────────────────────────────────────\n","# MERGE RESULTS\n","# ─────────────────────────────────────────────────────────────────────\n","df = pd.read_csv(CSV_FINAL, dtype=str)\n","\n","# Followers\n","if os.path.exists(CKPT_FOLLOWERS):\n","    fol_df       = pd.read_csv(CKPT_FOLLOWERS, dtype=str)\n","    fol_df       = fol_df.drop_duplicates(subset='video_url', keep='last')\n","    follower_map = fol_df.set_index('video_url')['creator_followers']\n","    df['creator_followers'] = df['video_url'].map(follower_map).fillna('0')\n","    ok_f = (pd.to_numeric(df['creator_followers'], errors='coerce') > 0).sum()\n","    print(f'creator_followers > 0: {ok_f}/731')\n","else:\n","    print('⚠️  No followers checkpoint found')\n","\n","# Comments\n","if os.path.exists(CKPT_COMMENTS_AP):\n","    com_df      = pd.read_csv(CKPT_COMMENTS_AP, dtype=str)\n","    com_df      = com_df.drop_duplicates(subset='video_url', keep='last')\n","    comment_map = com_df.set_index('video_url')['comment_text']\n","    df = df.drop(columns=['comment_text'], errors='ignore')\n","    df['comment_text'] = df['video_url'].map(comment_map).fillna('')\n","    ok_c = (df['comment_text'].str.strip() != '').sum()\n","    print(f'comment_text filled:   {ok_c}/731')\n","else:\n","    print('⚠️  No comments checkpoint found')\n","    df['comment_text'] = ''\n","\n","# ─────────────────────────────────────────────────────────────────────\n","# CLAUDE HAIKU: comment_stance + comment_sentiment\n","# ─────────────────────────────────────────────────────────────────────\n","print('\\n── Claude classify comments ─────────────────────────────────────')\n","\n","client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","\n","SYSTEM = \"\"\"You are classifying TikTok comments for a dermatology misinformation study.\n","Respond ONLY with a valid JSON object — no markdown, no explanation.\n","comment_stance:    supportive | skeptical | neutral | mixed\n","comment_sentiment: positive | negative | neutral | mixed\"\"\"\n","\n","VALID_STANCE    = {'supportive', 'skeptical', 'neutral', 'mixed'}\n","VALID_SENTIMENT = {'positive', 'negative', 'neutral', 'mixed'}\n","DEFAULT_CLS     = {'comment_stance': 'na', 'comment_sentiment': 'na'}\n","\n","def classify_comments(comment_text, retries=2):\n","    if not comment_text or str(comment_text).strip() in ('', 'nan'):\n","        return DEFAULT_CLS.copy()\n","    for attempt in range(retries + 1):\n","        try:\n","            resp = client.messages.create(\n","                model='claude-haiku-4-5-20251001',\n","                max_tokens=60,\n","                system=SYSTEM,\n","                messages=[{'role': 'user', 'content':\n","                    f'COMMENTS:\\n{str(comment_text)[:800]}\\n\\n'\n","                    'Return JSON with comment_stance and comment_sentiment.'}]\n","            )\n","            text = resp.content[0].text.strip()\n","            if text.startswith('```'):\n","                text = text.split('```')[1]\n","                if text.startswith('json'):\n","                    text = text[4:]\n","            result = json.loads(text)\n","            return {\n","                'comment_stance':    result.get('comment_stance', 'neutral')\n","                                     if result.get('comment_stance') in VALID_STANCE\n","                                     else 'neutral',\n","                'comment_sentiment': result.get('comment_sentiment', 'neutral')\n","                                     if result.get('comment_sentiment') in VALID_SENTIMENT\n","                                     else 'neutral'\n","            }\n","        except anthropic.RateLimitError:\n","            print('Rate limit — waiting 60s...')\n","            time.sleep(60)\n","        except json.JSONDecodeError:\n","            if attempt < retries:\n","                time.sleep(1)\n","        except Exception:\n","            if attempt < retries:\n","                time.sleep(2)\n","    return DEFAULT_CLS.copy()\n","\n","has_comments = (\n","    df['comment_text'].notna() &\n","    (df['comment_text'].str.strip() != '') &\n","    (df['comment_text'].str.strip() != 'nan')\n",")\n","to_classify = df[has_comments]\n","print(f'To classify: {len(to_classify)} | Cost: ~${len(to_classify) * 0.0001:.3f}')\n","\n","# Resume from checkpoint\n","if os.path.exists(CKPT_CLASSIFY):\n","    cls_ckpt    = pd.read_csv(CKPT_CLASSIFY, dtype=str)\n","    done_cls    = set(cls_ckpt['video_url'].tolist())\n","    cls_results = cls_ckpt.to_dict('records')\n","    print(f'Resuming — {len(done_cls)} already done')\n","else:\n","    done_cls, cls_results = set(), []\n","\n","rem_cls = to_classify[~to_classify['video_url'].isin(done_cls)]\n","\n","for _, row in tqdm(rem_cls.iterrows(), total=len(rem_cls)):\n","    ct  = row['comment_text'] if pd.notna(row['comment_text']) else ''\n","    cls = classify_comments(str(ct))\n","    cls['video_url'] = row['video_url']\n","    cls_results.append(cls)\n","    time.sleep(0.1)\n","    if len(cls_results) % 100 == 0:\n","        pd.DataFrame(cls_results).to_csv(CKPT_CLASSIFY, index=False)\n","        print(f'  Checkpoint: {len(cls_results)}')\n","\n","pd.DataFrame(cls_results).to_csv(CKPT_CLASSIFY, index=False)\n","\n","if cls_results:\n","    cls_df = pd.DataFrame(cls_results)\n","else:\n","    cls_df = pd.read_csv(CKPT_CLASSIFY, dtype=str)\n","\n","df = df.drop(columns=['comment_stance', 'comment_sentiment'], errors='ignore')\n","df = df.merge(\n","    cls_df[['video_url', 'comment_stance', 'comment_sentiment']],\n","    on='video_url', how='left'\n",")\n","df['comment_stance']    = df['comment_stance'].fillna('na')\n","df['comment_sentiment'] = df['comment_sentiment'].fillna('na')\n","\n","# ─────────────────────────────────────────────────────────────────────\n","# SAVE\n","# ─────────────────────────────────────────────────────────────────────\n","df.to_csv(CSV_COMPLETE, index=False)\n","\n","print('\\n' + '='*55)\n","print('COMPLETE')\n","print('='*55)\n","for col in ['creator_followers', 'comment_text', 'comment_stance', 'comment_sentiment']:\n","    if col in df.columns:\n","        filled = (\n","            df[col].notna() &\n","            (df[col].astype(str).str.strip() != '') &\n","            (df[col].astype(str).str.strip() != 'nan') &\n","            (df[col].astype(str).str.strip() != '0')\n","        ).sum()\n","        pct    = filled / len(df) * 100\n","        status = '✅' if pct > 80 else '⚠️ ' if pct > 0 else '❌'\n","        print(f'  {status} {col:<25} {filled}/731 ({pct:.1f}%)')\n","print(f'\\nSaved → {CSV_COMPLETE}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"f9wcrX_B2pkU","executionInfo":{"status":"error","timestamp":1776892253038,"user_tz":300,"elapsed":875367,"user":{"displayName":"Parth Patel","userId":"11950684250065582379"}},"outputId":"5a14a5a3-ab6d-4277-cb1c-ba9af98b717d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Apify token: ParthPatel0226\n","Apify memory in use: 0MB / 8192MB\n","✅ Loaded: 731 rows\n","\n","── Starting parallel scrape ─────────